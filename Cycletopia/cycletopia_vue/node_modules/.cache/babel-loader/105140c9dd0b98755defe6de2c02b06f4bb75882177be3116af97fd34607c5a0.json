\n                type: 'success',\r\n            }); // ToastOptions\r\n        }\r\n        return { notify };\r\n    },\r\n    setup() {\r\n        const showModal = ref(false)\r\n        const { modalProps } = useModal()\r\n\r\n        return {\r\n            showModal,\r\n            modalProps\r\n        }\r\n    },\r\n    methods: {\r\n        async deleteBike(id) {\r\n            this.$store.commit('setIsLoading', true)\r\n\r\n            await axios.delete('/api/v1/delete-bike/' + id)\r\n            .then(response => {\r\n                console.log(\"Delete successful.\")\r\n                this.notify();\r\n            })\r\n            .catch(error => {\r\n                console.log(error)\r\n            })\r\n\r\n            this.$store.commit('setIsLoading', false)\r\n        },\r\n        changeBikeIdToDelete(id) {\r\n            this.bikeIdtoDel = id;\r\n        }\r\n    }\r\n}\r\n</script>"]},"metadata":{},"sourceType":"module","externalDependencies":[]}