{"ast":null,"code":"import axios from 'axios';\nimport { toast } from 'vue3-toastify';\nimport 'vue3-toastify/dist/index.css';\nimport { useModal } from '@vueuse/core';\nexport default {\n  name: 'UserBikes',\n  props: {\n    bike: Object,\n    bikeIdtoDel: 0\n  },\n  setup() {\n    const notify = () => {\n      toast(\"Delete bike successful. Please refresh the page to view changes.\", {\n        autoClose: 2000,\n        position: 'bottom-right',\n        type: 'success'\n      }); // ToastOptions\n    };\n\n    return {\n      notify\n    };\n  },\n  setup() {\n    const showModal = ref(false);\n    const {\n      modalProps\n    } = useModal();\n    return {\n      showModal,\n      modalProps\n    };\n  },\n  methods: {\n    async deleteBike(id) {\n      this.$store.commit('setIsLoading', true);\n      await axios.delete('/api/v1/delete-bike/' + id).then(response => {\n        console.log(\"Delete successful.\");\n        this.notify();\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    },\n    changeBikeIdToDelete(id) {\n      this.bikeIdtoDel = id;\n    }\n  }\n};","map":{"version":3,"mappings":"AA6BA,OAAOA,KAAI,MAAO,OAAM;AACxB,SAASC,KAAI,QAAS,eAAe;AACrC,OAAO,8BAA8B;AACrC,SAASC,QAAO,QAAS,cAAa;AACtC,eAAe;EACXC,IAAI,EAAE,WAAW;EACjBC,KAAK,EAAE;IACHC,IAAI,EAAEC,MAAM;IACZC,WAAW,EAAE;EACjB,CAAC;EACDC,KAAK,GAAG;IACJ,MAAMC,MAAK,GAAI,MAAM;MACjBR,KAAK,CAAC,kEAAkE,EAAE;QACtES,SAAS,EAAE,IAAI;QACfC,QAAQ,EAAE,cAAc;QACxBC,IAAI,EAAE;MACV,CAAC,CAAC,EAAE;IACR;;IACA,OAAO;MAAEH;IAAO,CAAC;EACrB,CAAC;EACDD,KAAK,GAAG;IACJ,MAAMK,SAAQ,GAAIC,GAAG,CAAC,KAAK;IAC3B,MAAM;MAAEC;IAAW,IAAIb,QAAQ,EAAC;IAEhC,OAAO;MACHW,SAAS;MACTE;IACJ;EACJ,CAAC;EACDC,OAAO,EAAE;IACL,MAAMC,UAAU,CAACC,EAAE,EAAE;MACjB,IAAI,CAACC,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,IAAI;MAEvC,MAAMpB,KAAK,CAACqB,MAAM,CAAC,sBAAqB,GAAIH,EAAE,EAC7CI,IAAI,CAACC,QAAO,IAAK;QACdC,OAAO,CAACC,GAAG,CAAC,oBAAoB;QAChC,IAAI,CAAChB,MAAM,EAAE;MACjB,CAAC,EACAiB,KAAK,CAACC,KAAI,IAAK;Q