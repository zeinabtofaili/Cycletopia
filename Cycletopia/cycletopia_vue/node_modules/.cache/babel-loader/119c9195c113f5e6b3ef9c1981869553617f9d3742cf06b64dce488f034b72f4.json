{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from 'axios';\nexport default {\n  name: 'ScheduleAppointment',\n  data() {\n    return {\n      name: '',\n      bike_type: '',\n      time: '',\n      date: '',\n      availableTimes: [],\n      errors: []\n    };\n  },\n  mounted() {},\n  methods: {\n    submitData() {\n      this.errors = [];\n      if (this.bike_type === '') {\n        this.errors.push('The bike type field is missing!');\n      }\n      if (this.time === '') {\n        this.errors.push('The time field is missing!');\n      }\n      if (this.date === '') {\n        this.errors.push('The date field is missing!');\n      }\n      if (!this.errors.length) {\n        const formData = {\n          bike_type: this.bike_type,\n          date: this.date,\n          time: this.time\n        };\n        axios.post(\"/api/v1/make-appointment/\", {\n          data: formData\n        }).then(response => {\n          // console.log(response)\n          this.$router.push('/request-training/success');\n        }).catch(error => {\n          console.log(error);\n        });\n      }\n    },\n    async getAvailableTimes() {\n      const selectElement = document.getElementById('time-select');\n      await axios.get('/api/v1/get-times/' + this.date + '/').then(response => {\n        this.availableTimes = response.data;\n        console.log(typeof this.availableTimes);\n        console.log(this.availableTimes);\n        for (const time of this.availableTimes) {\n          const optionElement = document.createElement('option');\n          optionElement.value = time;\n          optionElement.text = time;\n          selectElement.appendChild(optionElement);\n        }\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n    changeDateSelected() {\n      const dateObj = new Date(this.date);\n      // Format the date as desired (yyyy-mm-dd)\n      const year = dateObj.getFullYear();\n      const month = ('0' + (dateObj.getMonth() + 1)).slice(-2); // add leading zero if needed\n      const day = ('0' + dateObj.getDate()).slice(-2); // add leading zero if needed\n      const formattedDate = `${year}-${month}-${day}`;\n      this.date = formattedDate;\n      // Output the formatted date\n      console.log(this.date);\n      this.time = '';\n      this.getAvailableTimes();\n    }\n  }\n};","map":{"version":3,"mappings":";AA+DA,OAAOA,KAAI,MAAO,OAAO;AAEzB,eAAe;EACXC,IAAI,EAAE,qBAAqB;EAE3BC,IAAI,GAAG;IACH,OAAO;MACHD,IAAI,EAAE,EAAE;MACRE,SAAS,EAAE,EAAE;MACbC,IAAI,EAAE,EAAE;MACRC,IAAI,EAAE,EAAE;MACRC,cAAc,EAAE,EAAE;MAClBC,MAAM,EAAE;IACZ,CAAC;EACL,CAAC;EACDC,OAAO,GAAG,CAEV,CAAC;EACDC,OAAO,EAAE;IACLC,UAAU,GAAG;MACT,IAAI,CAACH,MAAK,GAAI,EAAC;MACf,IAAI,IAAI,CAACJ,SAAQ,KAAM,EAAE,EAAE;QACvB,IAAI,CAACI,MAAM,CAACI,IAAI,CAAC,iCAAiC;MACtD;MACA,IAAI,IAAI,CAACP,IAAG,KAAM,EAAE,EAAE;QAClB,IAAI,CAACG,MAAM,CAACI,IAAI,CAAC,4BAA4B;MACjD;MACA,IAAI,IAAI,CAACN,IAAG,KAAM,EAAE,EAAE;QAClB,IAAI,CAACE,MAAM,CAACI,IAAI,CAAC,4BAA4B;MACjD;MACA,IAAI,CAAC,IAAI,CAACJ,MAAM,CAACK,MAAM,EAAE;QACrB,MAAMC,QAAO,GAAI;UACbV,SAAS,EAAE,IAAI,CAACA,SAAS;UACzBE,IAAI,EAAE,IAAI,CAACA,IAAI;UACfD,IAAI,EAAE,IAAI,CAACA;QACf;QACAJ,KAAI,CACCc,IAAI,CAAC,2BAA2B,EAAE;UAAEZ,IAAI,EAAEW;QAAS,CAAC,EACpDE,IAAI,CAACC,QAAO,IAAK;UACd;UACA,IAAI,CAACC,OAAO,CAACN,IAAI,CAAC,2BAA2B,CAAC;QAElD,CAAC,CAAC,CAACO,KAAK,CAACC,KAAI,IAAK;UACdC,OAAO,CAACC,GAAG,CAACF,KAAK;QACrB,CAAC;MACT;IACJ,CAAC;IACD,MAAMG,iBAAiB,GAAG;MACtB,MAAMC,aAAY,GAAIC,QAAQ,CAACC,cAAc,CAAC,aAAa,CAAC;MAC5D,MAAMzB,KAAK,CAAC0B,GAAG,CAAC,oBAAmB,GAAI,IAAI,CAACrB,IAAG,GAAG,GAAG,EAChDU,IAAI,CAACC,QAAO,IAAK;QACd,IAAI,CAACV,cAAa,GAAIU,QAAQ,CAACd,IAAG;QAClCkB,OAAO,CAACC,GAAG,CAAC,OAAO,IAAI,CAACf,cAAc,CAAC;QAEvCc,OAAO,CAACC,GAAG,CAAC,IAAI,CAACf,cAAc;QAC/B,KAAK,MAAMF,IAAG,IAAK,IAAI,CAACE,cAAc,EAAE;UACpC,MAAMqB,aAAY,GAAIH,QAAQ,CAACI,aAAa,CAAC,QAAQ,CAAC;UACtDD,aAAa,CAACE,KAAI,GAAIzB,IAAI;UAC1BuB,aAAa,CAACG,IAAG,GAAI1B,IAAI;UACzBmB,aAAa,CAACQ,WAAW,CAACJ,aAAa,CAAC;QAC5C;MACJ,CAAC,EACAT,KAAK,CAACC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAG,CAACF,KAAK;MACrB,CAAC;IACT,CAAC;IACDa,kBAAkB,GAAG;MACjB,MAAMC,OAAM,GAAI,IAAIC,IAAI,CAAC,IAAI,CAAC7B,IAAI,CAAC;MACnC;MACA,MAAM8B,IAAG,GAAIF,OAAO,CAACG,WAAW,EAAE;MAClC,MAAMC,KAAI,GAAI,CAAC,GAAE,IAAKJ,OAAO,CAACK,QAAQ,EAAC,GAAI,CAAC,CAAC,EAAEC,KAAK,CAAC,CAAC,CAAC,CAAC,EAAE;MAC1D,MAAMC,GAAE,GAAI,CAAC,GAAE,GAAIP,OAAO,CAACQ,OAAO,EAAE,EAAEF,KAAK,CAAC,CAAC,CAAC,CAAC,EAAE;MACjD,MAAMG,aAAY,GAAK,GAAEP,IAAK,IAAGE,KAAM,IAAGG,GAAI,EAAC;MAC/C,IAAI,CAACnC,IAAG,GAAIqC,aAAY;MACxB;MACAtB,OAAO,CAACC,GAAG,CAAC,IAAI,CAAChB,IAAI,CAAC;MACtB,IAAI,CAACD,IAAI,GAAC,EAAC;MACX,IAAI,CAACkB,iBAAiB,EAAC;IAC3B;EAEJ;AACJ,CAAC","names":["axios","name","data","bike_type","time","date","availableTimes","errors","mounted","methods","submitData","push","length","formData","post","then","response","$router","catch","error","console","log","getAvailableTimes","selectElement","document","getElementById","get","optionElement","createElement","value","text","appendChild","changeDateSelected","dateObj","Date","year","getFullYear","month","getMonth","slice","day","getDate","formattedDate"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\views\\ScheduleAppointment.vue"],"sourcesContent":["<template>\r\n    <div>\r\n        <div class=\"row g-3 shadow p-3 mb-5 bg-body rounded\">\r\n            <div class=\"col-md-6 d-none d-md-block position-relative\">\r\n                <img src=\"@/assets/cyclists.jpg\" class=\"img-fluid rounded shadow-lg\" style=\"height:100%;\" />\r\n\r\n            </div>\r\n\r\n            <div class=\"col-md-6\">\r\n                <h2>Request Training</h2>\r\n                <p style=\"margin-top: 15px;\">Please fill the following form. We will email you shortly with the link to fill\r\n                    the training date and time that suits you.</p>\r\n                <div class=\"row\">\r\n                    <div class=\"form-floating col-md-12 my-2\">\r\n                        <input type=\"text\" class=\"form-control\" v-model=\"name\" placeholder=\"Full name\">\r\n                        <label class=\"form-label p-3\">Full name</label>\r\n                    </div>\r\n\r\n                </div>\r\n\r\n                <br>\r\n                <div class=\"row\">\r\n                    <!-- <div class=\"form-floating col-md-4 my-2\">\r\n                        <input type=\"email\" class=\"form-control\" v-model=\"email\" placeholder=\"Email\">\r\n                        <label class=\"form-label p-3\">Email</label>\r\n                    </div>\r\n                    <div class=\"form-floating col-md-4 my-2\">\r\n                        <input type=\"text\" class=\"form-control\" v-model=\"phone\" placeholder=\"Phone\">\r\n                        <label class=\"form-label p-3\">Phone</label>\r\n                    </div> -->\r\n                    <div class=\"form-floating col-md-4 my-2\">\r\n                        <input type=\"date\" class=\"form-control\" v-model=\"date\" placeholder=\"Date\" v-on:change=\"changeDateSelected()\">\r\n                        <label class=\"form-label p-3\">Date</label>\r\n                    </div>\r\n                    <div class=\"form-floating col-md-4 my-2\">\r\n                        <select class=\"form-select\" v-model=\"time\" id=\"time-select\"></select>\r\n                        <label class=\"form-label p-3\">Time</label>\r\n                    </div>\r\n                    <div class=\"form-floating col-md-4 my-2\">\r\n                        <select class=\"form-select\" v-model=\"bike_type\">\r\n                            <option>Road</option>\r\n                            <option>Mountain</option>\r\n                            <option>Electric</option>\r\n\r\n                        </select>\r\n                        <label class=\"form-label p-3\">Bike type (select one):</label>\r\n                    </div>\r\n                </div>\r\n\r\n                <div class=\"d-grid gap-2 col-md-6 mx-auto\">\r\n                    <button style=\"margin-top: 20px;\" class=\"btn btn-dark\" @click=\"submitData\">Submit</button>\r\n\r\n                </div>\r\n\r\n            </div>\r\n        </div>\r\n        <div class=\"alert alert-danger\" v-if=\"errors.length\">\r\n            <p v-for=\"error in errors\" v-bind:key=\"error\">{{ error }}</p>\r\n        </div>\r\n    </div>\r\n</template>\r\n  \r\n<script>\r\nimport axios from 'axios';\r\n\r\nexport default {\r\n    name: 'ScheduleAppointment',\r\n\r\n    data() {\r\n        return {\r\n            name: '',\r\n            bike_type: '',\r\n            time: '',\r\n            date: '',\r\n            availableTimes: [],\r\n            errors: []\r\n        };\r\n    },\r\n    mounted() {\r\n\r\n    },\r\n    methods: {\r\n        submitData() {\r\n            this.errors = []\r\n            if (this.bike_type === '') {\r\n                this.errors.push('The bike type field is missing!')\r\n            }\r\n            if (this.time === '') {\r\n                this.errors.push('The time field is missing!')\r\n            }\r\n            if (this.date === '') {\r\n                this.errors.push('The date field is missing!')\r\n            }\r\n            if (!this.errors.length) {\r\n                const formData = {\r\n                    bike_type: this.bike_type,\r\n                    date: this.date,\r\n                    time: this.time,\r\n                }\r\n                axios\r\n                    .post(\"/api/v1/make-appointment/\", { data: formData })\r\n                    .then(response => {\r\n                        // console.log(response)\r\n                        this.$router.push('/request-training/success');\r\n\r\n                    }).catch(error => {\r\n                        console.log(error)\r\n                    })\r\n            }\r\n        },\r\n        async getAvailableTimes() {\r\n            const selectElement = document.getElementById('time-select');\r\n            await axios.get('/api/v1/get-times/' + this.date +'/')\r\n                .then(response => {\r\n                    this.availableTimes = response.data\r\n                    console.log(typeof this.availableTimes);\r\n\r\n                    console.log(this.availableTimes)\r\n                    for (const time of this.availableTimes) {\r\n                        const optionElement = document.createElement('option');\r\n                        optionElement.value = time;\r\n                        optionElement.text = time;\r\n                        selectElement.appendChild(optionElement);\r\n                    }\r\n                })\r\n                .catch(error => {\r\n                    console.log(error)\r\n                })\r\n        },\r\n        changeDateSelected() {\r\n            const dateObj = new Date(this.date);\r\n            // Format the date as desired (yyyy-mm-dd)\r\n            const year = dateObj.getFullYear();\r\n            const month = ('0' + (dateObj.getMonth() + 1)).slice(-2); // add leading zero if needed\r\n            const day = ('0' + dateObj.getDate()).slice(-2); // add leading zero if needed\r\n            const formattedDate = `${year}-${month}-${day}`;\r\n            this.date = formattedDate\r\n            // Output the formatted date\r\n            console.log(this.date);\r\n            this.time=''\r\n            this.getAvailableTimes()\r\n        }\r\n\r\n    },\r\n};\r\n</script>\r\n\r\n<style scoped></style>\r\n  "]},"metadata":{},"sourceType":"module","externalDependencies":[]}