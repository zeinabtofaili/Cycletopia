{"ast":null,"code":"import axios from 'axios';\nimport { toast } from 'vue3-toastify';\nimport 'vue3-toastify/dist/index.css';\nimport { Modal } from 'usemodal-vue3';\nexport default {\n  name: 'UserBikes',\n  props: {\n    bike: Object,\n    bikeIdtoDel: 0\n  },\n  setup() {\n    const notify = () => {\n      toast(\"Delete bike successful. Please refresh the page to view changes.\", {\n        autoClose: 2000,\n        position: 'bottom-right',\n        type: 'success'\n      }); // ToastOptions\n    };\n\n    return {\n      notify\n    };\n  },\n  methods: {\n    async deleteBike(id) {\n      this.$store.commit('setIsLoading', true);\n      await axios.delete('/api/v1/delete-bike/' + id).then(response => {\n        console.log(\"Delete successful.\");\n        this.notify();\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    },\n    changeBikeIdToDelete(id) {\n      this.bikeIdtoDel = id;\n    }\n  }\n};","map":{"version":3,"mappings":"AAyBA,OAAOA,KAAI,MAAO,OAAM;AACxB,SAASC,KAAI,QAAS,eAAe;AACrC,OAAO,8BAA8B;AACrC,SAASC,KAAI,QAAS,eAAe;AAErC,eAAe;EACXC,IAAI,EAAE,WAAW;EACjBC,KAAK,EAAE;IACHC,IAAI,EAAEC,MAAM;IACZC,WAAW,EAAE;EACjB,CAAC;EACDC,KAAK,GAAG;IACJ,MAAMC,MAAK,GAAI,MAAM;MACjBR,KAAK,CAAC,kEAAkE,EAAE;QACtES,SAAS,EAAE,IAAI;QACfC,QAAQ,EAAE,cAAc;QACxBC,IAAI,EAAE;MACV,CAAC,CAAC,EAAE;IACR;;IACA,OAAO;MAAEH;IAAO,CAAC;EACrB,CAAC;EACDI,OAAO,EAAE;IACL,MAAMC,UAAU,CAACC,EAAE,EAAE;MACjB,IAAI,CAACC,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,IAAI;MAEvC,MAAMjB,KAAK,CAACkB,MAAM,CAAC,sBAAqB,GAAIH,EAAE,EACzCI,IAAI,CAACC,QAAO,IAAK;QACdC,OAAO,CAACC,GAAG,CAAC,oBAAoB;QAChC,IAAI,CAACb,MAAM,EAAE;MACjB,CAAC,EACAc,KAAK,CAACC,KAAI,IAAK;QACZH,OAAO,CAACC,GAAG,CAACE,KAAK;MACrB,CAAC;MAEL,IAAI,CAACR,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,KAAK;IAC5C,CAAC;IACDQ,oBAAoB,CAACV,EAAE,EAAE;MACrB,IAAI,CAACR,WAAU,GAAIQ,EAAE;IACzB;EACJ;AACJ","names":["axios","toast","Modal","name","props","bike","Object","bikeIdtoDel","setup","notify","autoClose","position"