{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from 'axios';\nimport OrderSummary from '@/components/OrderSummary.vue';\nimport UserBikes from '@/components/MyBikes.vue';\nimport { toast } from 'vue3-toastify';\nimport 'vue3-toastify/dist/index.css';\nexport default {\n  name: 'MyAccountView',\n  components: {\n    OrderSummary,\n    UserBikes\n  },\n  setup() {\n    const notify = () => {\n      toast(\"Delete bike successful. Please refresh the page to view changes.\", {\n        autoClose: 2000,\n        position: 'bottom-right',\n        type: 'success'\n      }); // ToastOptions\n    };\n\n    return {\n      notify\n    };\n  },\n  data() {\n    return {\n      orders: [],\n      bikes: [],\n      bikeIdtoDel: 0\n    };\n  },\n  mounted() {\n    document.title = 'My account | Cycletopia';\n    this.getMyOrders();\n    this.getMyBikes();\n  },\n  methods: {\n    logout() {\n      axios.defaults.headers.common[\"Authorization\"] = \"\";\n      localStorage.removeItem(\"token\");\n      localStorage.removeItem(\"userid\");\n      localStorage.removeItem(\"username\");\n      this.$store.commit('removeToken');\n      this.$router.push('/');\n    },\n    async getMyOrders() {\n      this.$store.commit('setIsLoading', true);\n      await axios.get('/api/v1/orders/').then(response => {\n        this.orders = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    },\n    async getMyBikes() {\n      this.$store.commit('setIsLoading', true);\n      await axios.get('/api/v1/current-user-bikes/').then(response => {\n        this.bikes = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    },\n    async deleteBike(id) {\n      this.$store.commit('setIsLoading', true);\n      await axios.delete('/api/v1/delete-bike/' + id).then(response => {\n        console.log(\"Delete successful.\");\n        this.notify();\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    },\n    changeBikeIdToDelete(id) {\n      bikeIdtoDel = id;\n      console.log(bikeIdtoDel);\n    }\n  }\n};","map":{"version":3,"mappings":";AAiDA,OAAOA,KAAI,MAAO,OAAM;AAExB,OAAOC,YAAW,MAAO,+BAA8B;AACvD,OAAOC,SAAQ,MAAO,0BAAyB;AAC/C,SAASC,KAAI,QAAS,eAAe;AACrC,OAAO,8BAA8B;AACrC,eAAe;EACXC,IAAI,EAAE,eAAe;EACrBC,UAAU,EAAE;IACRJ,YAAY;IACZC;EACJ,CAAC;EACDI,KAAK,GAAG;IACJ,MAAMC,MAAK,GAAI,MAAM;MACjBJ,KAAK,CAAC,kEAAkE,EAAE;QACtEK,SAAS,EAAE,IAAI;QACfC,QAAQ,EAAE,cAAc;QACxBC,IAAI,EAAE;MACV,CAAC,CAAC,EAAE;IACR;;IACA,OAAO;MAAEH;IAAO,CAAC;EACrB,CAAC;EACDI,IAAI,GAAG;IACH,OAAO;MACHC,MAAM,EAAE,EAAE;MACVC,KAAK,EAAE,EAAE;MACTC,WAAW,EAAE;IACjB;EACJ,CAAC;EACDC,OAAO,GAAG;IACNC,QAAQ,CAACC,KAAI,GAAI,yBAAwB;IAEzC,IAAI,CAACC,WAAW,EAAE;IAClB,IAAI,CAACC,UAAU,EAAE;EACrB,CAAC;EACDC,OAAO,EAAE;IACLC,MAAM,GAAG;MACLrB,KAAK,CAACsB,QAAQ,CAACC,OAAO,CAACC,MAAM,CAAC,eAAe,IAAI,EAAC;MAElDC,YAAY,CAACC,UAAU,CAAC,OAAO;MAC/BD,YAAY,CAACC,UAAU,CAAC,QAAQ;MAChCD,YAAY,CAACC,UAAU,CAAC,UAAU;MAElC,IAAI,CAACC,MAAM,CAACC,MAAM,CAAC,aAAa;MAEhC,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,GAAG;IACzB,CAAC;IACD,MAAMZ,WAAW,GAAG;MAChB,IAAI,CAACS,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,IAAI;MAEvC,MAAM5B,KAAI,CACL+B,GAAG,CAAC,iBAAiB,EACrBC,IAAI,CAACC,QAAO,IAAK;QACd,IAAI,CAACrB,MAAK,GAAIqB,QAAQ,CAACtB,IAAG;MAC9B,CAAC,EACAuB,KAAK,CAACC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAG,CAACF,KAAK;MACrB,CAAC;MAEL,IAAI,CAACR,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,KAAK;IAC5C,CAAC;IACD,MAAMT,UAAU,GAAG;MACf,IAAI,CAACQ,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,IAAI;MAEvC,MAAM5B,KAAI,CACL+B,GAAG,CAAC,6BAA6B,EACjCC,IAAI,CAACC,QAAO,IAAK;QACd,IAAI,CAACpB,KAAI,GAAIoB,QAAQ,CAACtB,IAAG;MAC7B,CAAC,EACAuB,KAAK,CAACC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAG,CAACF,KAAK;MACrB,CAAC;MAEL,IAAI,CAACR,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,KAAK;IAC5C,CAAC;IACD,MAAMU,UAAU,CAACC,EAAE,EAAE;MACjB,IAAI,CAACZ,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,IAAI;MAEvC,MAAM5B,KAAK,CAACwC,MAAM,CAAC,sBAA