{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from 'axios';\nexport default {\n  name: 'ScheduleAppointment',\n  data() {\n    return {\n      bike_type: '',\n      time: '',\n      date: '',\n      errors: []\n    };\n  },\n  mounted() {},\n  methods: {\n    submitData() {\n      this.errors = [];\n      if (this.bike_type === '') {\n        this.errors.push('The bike type field is missing!');\n      }\n      if (this.time === '') {\n        this.errors.push('The time field is missing!');\n      }\n      if (this.date === '') {\n        this.errors.push('The date field is missing!');\n      }\n      if (!this.errors.length) {\n        const formData = {\n          bike_type: this.bike_type,\n          date: this.date,\n          time: this.time\n        };\n      }\n    }\n  }\n};","map":{"version":3,"mappings":";AAsDA,OAAOA,KAAI,MAAO,OAAO;AAEzB,eAAe;EACXC,IAAI,EAAE,qBAAqB;EAE3BC,IAAI,GAAG;IACH,OAAO;MACHC,SAAS,EAAE,EAAE;MACbC,IAAI,EAAE,EAAE;MACRC,IAAI,EAAE,EAAE;MACRC,MAAM,EAAE;IACZ,CAAC;EACL,CAAC;EACDC,OAAO,GAAG,CAEV,CAAC;EACDC,OAAO,EAAE;IACLC,UAAU,GAAG;MACT,IAAI,CAACH,MAAK,GAAI,EAAC;MACf,IAAI,IAAI,CAACH,SAAQ,KAAM,EAAE,EAAE;QACvB,IAAI,CAACG,MAAM,CAACI,IAAI,CAAC,iCAAiC;MACtD;MACA,IAAI,IAAI,CAACN,IAAG,KAAM,EAAE,EAAE;QAClB,IAAI,CAACE,MAAM,CAACI,IAAI,CAAC,4BAA4B;MACjD;MACA,IAAI,IAAI,CAACL,IAAG,KAAM,EAAE,EAAE;QAClB,IAAI,CAACC,MAAM,CAACI,IAAI,CAAC,4BAA4B;MACjD;MACA,IAAI,CAAC,IAAI,CAACJ,MAAM,CAACK,MAAM,EAAE;QACrB,MAAMC,QAAO,GAAI;UACbT,SAAQ,EAAI,IAAI,CAACA,SAAS;UAC1BE,IAAG,EAAI,IAAI,CAACA,IAAI;UAChBD,IAAG,EAAG,IAAI,CAACA;QACf;MACJ;IACJ;EAEJ;AACJ,CAAC","names":["axios","name","data","bike_type","time","date","errors","mounted","methods","submitData","push","length","formData"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\views\\ScheduleAppointment.vue"],"sourcesContent":["<template>\r\n    <div>\r\n        <div class=\"row g-3 shadow p-3 mb-5 bg-body rounded\">\r\n            <div class=\"col-md-6 d-none d-md-block position-relative\">\r\n                <img src=\"@/assets/cyclists.jpg\" class=\"img-fluid rounded shadow-lg\" style=\"height:100%;\" />\r\n\r\n            </div>\r\n\r\n            <div class=\"col-md-6\">\r\n                <h2>Request Training</h2>\r\n                <p style=\"margin-top: 15px;\">Please fill the following form. We will email you shortly with the link to fill the training date and time that suits you.</p>\r\n                <div class=\"row\">\r\n                    <div class=\"form-floating col-md-12 my-2\">\r\n                        <input type=\"text\" class=\"form-control\" v-model=\"name\" placeholder=\"Full name\">\r\n                        <label class=\"form-label p-3\">Full name</label>\r\n                    </div>\r\n\r\n                </div>\r\n\r\n                <br>\r\n                <div class=\"row\">\r\n                    <div class=\"form-floating col-md-4 my-2\">\r\n                        <input type=\"email\" class=\"form-control\" v-model=\"email\" placeholder=\"Email\">\r\n                        <label class=\"form-label p-3\">Email</label>\r\n                    </div>\r\n                    <div class=\"form-floating col-md-4 my-2\">\r\n                        <input type=\"text\" class=\"form-control\" v-model=\"phoneNumber\" placeholder=\"Phone\">\r\n                        <label class=\"form-label p-3\">Phone</label>\r\n                    </div>\r\n                    <div class=\"form-floating col-md-4 my-2\">\r\n                        <select class=\"form-select\" v-model=\"grouping\">\r\n                            <option>Road</option>\r\n                            <option>Mountain</option>\r\n                            <option>Electric</option>\r\n\r\n                        </select>\r\n                        <label class=\"form-label p-3\">Bike type (select one):</label>\r\n                    </div>\r\n                </div>\r\n\r\n                <div class=\"d-grid gap-2 col-md-6 mx-auto\">\r\n                    <button style=\"margin-top: 20px;\" class=\"btn btn-dark\" @click=\"submitData\">Submit</button>\r\n\r\n                </div>\r\n\r\n            </div>\r\n        </div>\r\n        <!-- <div class=\"alert alert-danger\" v-if=\"errors.length\">\r\n            <p v-for=\"error in errors\" v-bind:key=\"error\">{{ error }}</p>\r\n        </div> -->\r\n    </div>\r\n</template>\r\n  \r\n<script>\r\nimport axios from 'axios';\r\n\r\nexport default {\r\n    name: 'ScheduleAppointment',\r\n\r\n    data() {\r\n        return {\r\n            bike_type: '',\r\n            time: '',\r\n            date: '',\r\n            errors: []\r\n        };\r\n    },\r\n    mounted() {\r\n\r\n    },\r\n    methods: {\r\n        submitData() {\r\n            this.errors = []\r\n            if (this.bike_type === '') {\r\n                this.errors.push('The bike type field is missing!')\r\n            }\r\n            if (this.time === '') {\r\n                this.errors.push('The time field is missing!')\r\n            }\r\n            if (this.date === '') {\r\n                this.errors.push('The date field is missing!')\r\n            }\r\n            if (!this.errors.length) {\r\n                const formData = {\r\n                    bike_type : this.bike_type,\r\n                    date : this.date,\r\n                    time :this.time,\r\n                }\r\n            }\r\n        }\r\n\r\n    },\r\n};\r\n</script>\r\n\r\n<style scoped></style>\r\n  "]},"metadata":{},"sourceType":"module","externalDependencies":[]}