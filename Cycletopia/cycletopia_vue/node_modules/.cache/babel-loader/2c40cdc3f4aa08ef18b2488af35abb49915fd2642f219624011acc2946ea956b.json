\ScheduleAppointment.vue"],"sourcesContent":["<template>\r\n    <div>\r\n        <div class=\"row g-3 shadow p-3 mb-5 bg-body rounded\">\r\n            <div class=\"col-md-6 d-none d-md-block position-relative\">\r\n                <img src=\"@/assets/cyclists.jpg\" class=\"img-fluid rounded shadow-lg\" style=\"height:100%;\" />\r\n\r\n            </div>\r\n\r\n            <div class=\"col-md-6\">\r\n                <h2>Request Training</h2>\r\n                <p style=\"margin-top: 15px;\">Please fill the following form. We will email you shortly with the link to fill\r\n                    the training date and time that suits you.</p>\r\n                <div class=\"row\">\r\n                    <div class=\"form-floating col-md-12 my-2\">\r\n                        <input type=\"text\" class=\"form-control\" v-model=\"name\" placeholder=\"Full name\">\r\n                        <label class=\"form-label p-3\">Full name</label>\r\n                    </div>\r\n\r\n                </div>\r\n\r\n                <br>\r\n                <div class=\"row\">\r\n                    <div class=\"form-floating col-md-4 my-2\">\r\n                        <input type=\"email\" class=\"form-control\" v-model=\"email\" placeholder=\"Email\">\r\n                        <label class=\"form-label p-3\">Email</label>\r\n                    </div>\r\n                    <div class=\"form-floating col-md-4 my-2\">\r\n                        <input type=\"text\" class=\"form-control\" v-model=\"phoneNumber\" placeholder=\"Phone\">\r\n                        <label class=\"form-label p-3\">Phone</label>\r\n                    </div>\r\n                    <div class=\"form-floating col-md-4 my-2\">\r\n                        <select class=\"form-select\" v-model=\"grouping\">\r\n                            <option>Road</option>\r\n                            <option>Mountain</option>\r\n                            <option>Electric</option>\r\n\r\n                        </select>\r\n                        <label class=\"form-label p-3\">Bike type (select one):</label>\r\n                    </div>\r\n                </div>\r\n\r\n                <div class=\"d-grid gap-2 col-md-6 mx-auto\">\r\n                    <button style=\"margin-top: 20px;\" class=\"btn btn-dark\" @click=\"submitData\">Submit</button>\r\n\r\n                </div>\r\n\r\n            </div>\r\n        </div>\r\n        <div class=\"alert alert-danger\" v-if=\"errors.length\">\r\n            <p v-for=\"error in errors\" v-bind:key=\"error\">{{ error }}</p>\r\n        </div>\r\n    </div>\r\n</template>\r\n  \r\n<script>\r\nimport axios from 'axios';\r\n\r\nexport default {\r\n    name: 'ScheduleAppointment',\r\n\r\n    data() {\r\n        return {\r\n            bike_type: '',\r\n            time: '',\r\n            date: '',\r\n            errors: []\r\n        };\r\n    },\r\n    mounted() {\r\n\r\n    },\r\n    methods: {\r\n        submitData() {\r\n            this.errors = []\r\n            if (this.bike_type === '') {\r\n                this.errors.push('The bike type field is missing!')\r\n            }\r\n            if (this.time === '') {\r\n                this.errors.push('The time field is missing!')\r\n            }\r\n            if (this.date === '') {\r\n                this.errors.push('The date field is missing!')\r\n            }\r\n            if (!this.errors.length) {\r\n                const formData = {\r\n                    bike_type: this.bike_type,\r\n                    date: this.date,\r\n                    time: this.time,\r\n                }\r\n                axios\r\n                    .post(\"/api/v1/make-appointment/\", { data: formData })\r\n                    .then(response => {\r\n                        // console.log(response)\r\n                        this.$router.push('/request-training/success');\r\n\r\n                    }).catch(error => {\r\n                        console.log(error)\r\n                    })\r\n            }\r\n        },\r\n        async getAvailableTimes() {\r\n            await axios.get('/api/v1/get-times/' + this.date)\r\n                .then(response => {\r\n                    console.log(response.data)\r\n                })\r\n                .catch(error => {\r\n                    console.log(error)\r\n                })\r\n        },\r\n        changeDateSelected(date) {\r\n            const dateObj = new Date(date);\r\n            // Format the date as desired (yyyy-mm-dd)\r\n            const year = dateObj.getFullYear();\r\n            const month = ('0' + (dateObj.getMonth() + 1)).slice(-2); // add leading zero if needed\r\n            const day = ('0' + dateObj.getDate()).slice(-2); // add leading zero if needed\r\n            const formattedDate = `${year}-${month}-${day}`;\r\n            this.date = formattedDate\r\n            // Output the formatted date\r\n            console.log(date);\r\n        }\r\n\r\n    },\r\n};\r\n</script>\r\n\r\n<style scoped></style>\r\n  "]},"metadata":{},"sourceType":"module","externalDependencies":[]}