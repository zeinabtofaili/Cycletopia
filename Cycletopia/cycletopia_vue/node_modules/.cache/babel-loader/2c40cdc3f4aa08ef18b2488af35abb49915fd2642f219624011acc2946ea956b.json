{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from 'axios';\nexport default {\n  name: 'ScheduleAppointment',\n  data() {\n    return {\n      bike_type: '',\n      time: '',\n      date: '',\n      errors: []\n    };\n  },\n  mounted() {},\n  methods: {\n    submitData() {\n      this.errors = [];\n      if (this.bike_type === '') {\n        this.errors.push('The bike type field is missing!');\n      }\n      if (this.time === '') {\n        this.errors.push('The time field is missing!');\n      }\n      if (this.date === '') {\n        this.errors.push('The date field is missing!');\n      }\n      if (!this.errors.length) {\n        const formData = {\n          bike_type: this.bike_type,\n          date: this.date,\n          time: this.time\n        };\n        axios.post(\"/api/v1/make-appointment/\", {\n          data: formData\n        }).then(response => {\n          // console.log(response)\n          this.$router.push('/request-training/success');\n        }).catch(error => {\n          console.log(error);\n        });\n      }\n    },\n    async getAvailableTimes() {\n      await axios.get('/api/v1/get-times/' + this.date).then(response => {\n        console.log(response.data);\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n    changeDateSelected(date) {\n      const dateObj = new Date(date);\n      // Format the date as desired (yyyy-mm-dd)\n      const year = dateObj.getFullYear();\n      const month = ('0' + (dateObj.getMonth() + 1)).slice(-2); // add leading zero if needed\n      const day = ('0' + dateObj.getDate()).slice(-2); // add leading zero if needed\n      const formattedDate = `${year}-${month}-${day}`;\n      this.date = formattedDate;\n      // Output the formatted date\n      console.log(date);\n    }\n  }\n};","map":{"version":3,"mappings":";AAuDA,OAAOA,KAAI,MAAO,OAAO;AAEzB,eAAe;EACXC,IAAI,EAAE,qBAAqB;EAE3BC,IAAI,GAAG;IACH,OAAO;MACHC,SAAS,EAAE,EAAE;MACbC,IAAI,EAAE,EAAE;MACRC,I