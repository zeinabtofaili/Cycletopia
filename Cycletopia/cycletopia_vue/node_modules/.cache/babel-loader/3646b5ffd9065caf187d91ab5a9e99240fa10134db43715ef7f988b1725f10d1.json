{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from 'axios';\nexport default {\n  name: 'ScheduleAppointment',\n  data() {\n    return {\n      email: '',\n      phone: '',\n      bike_type: '',\n      time: '',\n      date: '',\n      availableTimes: [],\n      errors: []\n    };\n  },\n  mounted() {\n    const today = new Date().toISOString().split('T')[0];\n    const tomorrow = new Date(new Date(today).setDate(new Date(today).getDate() + 1)).toISOString().split('T')[0];\n    const maxDate = new Date(new Date(today).setDate(new Date(today).getDate() + 7)).toISOString().split('T')[0];\n    document.getElementById(\"myDate\").setAttribute(\"min\", tomorrow);\n    document.getElementById(\"myDate\").setAttribute(\"max\", maxDate);\n  },\n  methods: {\n    submitData() {\n      this.errors = [];\n      if (this.email === '') {\n        this.errors.push('The email field is missing!');\n      }\n      if (this.phone === '') {\n        this.errors.push('The phone field is missing!');\n      }\n      if (this.bike_type === '') {\n        this.errors.push('The bike type field is missing!');\n      }\n      if (this.time === '') {\n        this.errors.push('The time field is missing!');\n      }\n      if (this.date === '') {\n        this.errors.push('The date field is missing!');\n      }\n      if (!this.errors.length) {\n        const formData = {\n          email: this.email,\n          phone: this.phone,\n          bike_type: this.bike_type,\n          date: this.date,\n          time: this.time\n        };\n        console.log(formData);\n        axios.post(\"/api/v1/make-appointment/\", formData).then(response => {\n          this.$router.push('/request-training/success');\n        }).catch(error => {\n          console.log(error);\n        });\n      }\n    },\n    async getAvailableTimes() {\n      const selectElement = document.getElementById('time-select');\n      await axios.get('/api/v1/get-times/' + this.date + '/').then(response => {\n        this.availableTimes = response.data.available_times;\n        for (const time of this.availableTimes) {\n          const optionElement = document.createElement('option');\n          optionElement.value = time;\n          optionElement.text = time;\n          selectElement.appendChild(optionElement);\n        }\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n    changeDateSelected() {\n      const dateObj = new Date(this.date);\n      const year = dateObj.getFullYear();\n      const month = ('0' + (dateObj.getMonth() + 1)).slice(-2);\n      const day = ('0' + dateObj.getDate()).slice(-2);\n      const formattedDate = `${year}-${month}-${day}`;\n      this.date = formattedDate;\n      console.log(this.date);\n      this.time = '';\n      this.getAvailableTimes();\n    }\n  }\n};","map":{"version":3,"mappings":";AAwDA,OAAOA,KAAI,MAAO,OAAO;AAEzB,eAAe;EACXC,IAAI,EAAE,qBAAqB;EAE3BC,IAAI,GAAG;IACH,OAAO;MACHC,KAAK,EAAE,EAAE;MACTC,KAAK,EAAE,EAAE;MACTC,SAAS,EAAE,EAAE;MACbC,IAAI,EAAE,EAAE;MACRC,IAAI,EAAE,EAAE;MACRC,cAAc,EAAE,EAAE;MAClBC,MAAM,EAAE;IACZ,CAAC;EACL,CAAC;EACDC,OAAO,GAAG;IACN,MAAMC,KAAI,GAAI,IAAIC,IAAI,EAAE,CAACC,WAAW,EAAE,CAACC,KAAK,CAAC,GAAG,CAAC,CAAC,CAAC,CAAC;IACpD,MAAMC,QAAO,GAAI,IAAIH,IAAI,CAAC,IAAIA,IAAI,CAACD,KAAK,CAAC,CAACK,OAAO,CAAC,IAAIJ,IAAI,CAACD,KAAK,CAAC,CAACM,OAAO,EAAC,GAAI,CAAC,CAAC,CAAC,CAACJ,WAAW,EAAE,CAACC,KAAK,CAAC,GAAG,CAAC,CAAC,CAAC,CAAC;IAC7G,MAAMI,OAAM,GAAI,IAAIN,IAAI,CAAC,IAAIA,IAAI,CAACD,KAAK,CAAC,CAACK,OAAO,CAAC,IAAIJ,IAAI,CAACD,KAAK,CAAC,CAACM,OAAO,EAAC,GAAI,CAAC,CAAC,CAAC,CAACJ,WAAW,EAAE,CAACC,KAAK,CAAC,GAAG,CAAC,CAAC,CAAC,CAAC;IAE5GK,QAAQ,CAACC,cAAc,CAAC,QAAQ,CAAC,CAACC,YAAY,CAAC,KAAK,EAAEN,QAAQ,CAAC;IAC/DI,QAAQ,CAACC,cAAc,CAAC,QAAQ,CAAC,CAACC,YAAY,CAAC,KAAK,EAAEH,OAAO,CAAC;EAElE,CAAC;EAEDI,OAAO,EAAE;IACLC,UAAU,GAAG;MACT,IAAI,CAACd,MAAK,GAAI,EAAC;MACf,IAAI,IAAI,CAACN,KAAI,KAAM,EAAE,EAAE;QACnB,IAAI,CAACM,MAAM,CAACe,IAAI,CAAC,6BAA6B;MAClD;MACA,IAAI,IAAI,CAACpB,KAAI,KAAM,EAAE,EAAE;QACnB,IAAI,CA