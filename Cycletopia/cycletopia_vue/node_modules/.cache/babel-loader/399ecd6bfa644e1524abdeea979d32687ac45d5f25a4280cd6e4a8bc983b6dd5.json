{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from 'axios';\nexport default {\n  name: 'ScheduleAppointment',\n  data() {\n    return {\n      email: '',\n      phone: '',\n      bike_type: '',\n      time: '',\n      date: '',\n      availableTimes: [],\n      errors: []\n    };\n  },\n  mounted() {},\n  methods: {\n    submitData() {\n      this.errors = [];\n      if (this.email === '') {\n        this.errors.push('The email field is missing!');\n      }\n      if (this.phone === '') {\n        this.errors.push('The phone field is missing!');\n      }\n      if (this.bike_type === '') {\n        this.errors.push('The bike type field is missing!');\n      }\n      if (this.time === '') {\n        this.errors.push('The time field is missing!');\n      }\n      if (this.date === '') {\n        this.errors.push('The date field is missing!');\n      }\n      if (!this.errors.length) {\n        const formData = {\n          email: this.email,\n          phone: this.phone,\n          bike_type: this.bike_type,\n          date: this.date,\n          time: this.time\n        };\n        axios.post(\"/api/v1/make-appointment/\", {\n          data: formData\n        }).then(response => {\n          this.$router.push('/request-training/success');\n        }).catch(error => {\n          console.log(error);\n        });\n      }\n    },\n    async getAvailableTimes() {\n      const selectElement = document.getElementById('time-select');\n      await axios.get('/api/v1/get-times/' + this.date + '/').then(response => {\n        this.availableTimes = response.data.available_times;\n        for (const time of this.availableTimes) {\n          const optionElement = document.createElement('option');\n          optionElement.value = time;\n          optionElement.text = time;\n          selectElement.appendChild(optionElement);\n        }\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n    changeDateSelected() {\n      const dateObj = new Date(this.date);\n      const year = dateObj.getFullYear();\n      const month = ('0' + (dateObj.getMonth() + 1)).slice(-2);\n      const day = ('0' + dateObj.getDate()).slice(-2);\n      const formattedDate = `${year}-${month}-${day}`;\n      this.date = formattedDate;\n      console.log(this.date);\n      this.time = '';\n      this.getAvailableTimes();\n    }\n  }\n};","map":{"version":3,"mappings":";AAuDA,OAAOA,KAAI,MAAO,OAAO;AAEzB,eAAe;EACXC,IAAI,EAAE,qBAAqB;EAE3BC,IAAI,GAAG;IACH,OAAO;MACHC,KAAK,EAAE,EAAE;MACTC,KAAK,EAAE,EAAE;MACTC,SAAS,EAAE,EAAE;MACbC,IAAI,EAAE,EAAE;MACRC,IAAI,EAAE,EAAE;MACRC,cAAc,EAAE,EAAE;MAClBC,MAAM,EAAE;IACZ,CAAC;EACL,CAAC;EACDC,OAAO,GAAG,CAEV,CAAC;EACDC,OAAO,EAAE;IACLC,UAAU,GAAG;MACT,IAAI,CAACH,MAAK,GAAI,EAAC;MACf,IAAI,IAAI,CAACN,KAAI,KAAM,EAAE,EAAE;QACnB,IAAI,CAACM,MAAM,CAACI,IAAI,CAAC,6BAA6B;MAClD;MACA,IAAI,IAAI,CAACT,KAAI,KAAM,EAAE,EAAE;QACnB,IAAI,CAACK,MAAM,CAACI,IAAI,CAAC,6BAA6B;MAClD;MACA,IAAI,IAAI,CAACR,SAAQ,KAAM,EAAE,EAAE;QACvB,IAAI,CAACI,MAAM,CAACI,IAAI,CAAC,iCAAiC;MACtD;MACA,IAAI,IAAI,CAACP,IAAG,KAAM,EAAE,EAAE;QAClB,IAAI,CAACG,MAAM,CAACI,IAAI,CAAC,4BAA4B;MACjD;MACA,IAAI,IAAI,CAACN,IAAG,KAAM,EAAE,EAAE;QAClB,IAAI,CAACE,MAAM,CAACI,IAAI,CAAC,4BAA4B;MACjD;MACA,IAAI,CAAC,IAAI,CAACJ,MAAM,CAACK,MAAM,EAAE;QACrB,MAAMC,QAAO,GAAI;UACbZ,KAAK,EAAE,IAAI,CAACA,KAAK;UACjBC,KAAK,EAAE,IAAI,CAACA,KAAK;UACjBC,SAAS,EAAE,IAAI,CAACA,SAAS;UACzBE,IAAI,EAAE,IAAI,CAACA,IAAI;UACfD,IAAI,EAAE,IAAI,CAACA;QACf;QACAN,KAAI,CACCgB,IAAI,CAAC,2BAA2B,EAAE;UAAEd,IAAI,EAAEa;QAAS,CAAC,EACpDE,IAAI,CAACC,QAAO,IAAK;UACd,IAAI,CAACC,OAAO,CAACN,IAAI,CAAC,2BAA2B,CAAC;QAElD,CAAC,CAAC,CAACO,KAAK,CAACC,KAAI,IAAK;UACdC,OAAO,CAACC,GAAG,CAACF,KAAK;QACrB,CAAC;MACT;IACJ,CAAC;IACD,MAAMG,iBAAiB,GAAG;MACtB,MAAMC,aAAY,GAAIC,QAAQ,CAACC,cAAc,CAAC,aAAa,CAAC;MAC5D,MAAM3B,KAAK,CAAC4B,GAAG,CAAC,oBAAmB,GAAI,IAAI,CAACrB,IAAG,GAAG,GAAG,EAChDU,IAAI,CAACC,QAAO,IAAK;QACd,IAAI,CAACV,cAAa,GAAIU,QAAQ,CAAChB,IAAI,CAAC2B,eAAc;QAClD,KAAK,MAAMvB,IAAG,IAAK,IAAI,CAACE,cAAc,EAAE;UACpC,MAAMsB,aA