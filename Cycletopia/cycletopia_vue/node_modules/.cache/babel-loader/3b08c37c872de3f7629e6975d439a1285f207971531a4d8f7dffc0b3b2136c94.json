{"ast":null,"code":"export default {\n  name: 'CartItem',\n  props: {\n    initialItem: Object\n  },\n  data() {\n    return {\n      item: this.initialItem\n    };\n  },\n  methods: {\n    getItemTotal(item) {\n      return item.quantity * item.product.price;\n    },\n    decrementQuantity(item) {\n      item.quantity -= 1;\n      if (item.quantity === 0) {\n        this.$emit('removeFromCart', item);\n      }\n      this.updateCart();\n    },\n    incrementQuantity(item) {\n      item.quantity += 1;\n      this.updateCart();\n    },\n    updateCart() {\n      localStorage.setItem('cart', JSON.stringify(this.$store.state.cart));\n    },\n    removeFromCart(item) {\n      this.$emit('removeFromCart', item);\n      this.updateCart();\n    }\n  }\n};","map":{"version":3,"mappings":"AAkBA,eAAe;EACXA,IAAI,EAAE,UAAU;EAChBC,KAAK,EAAE;IACHC,WAAW,EAAEC;EACjB,CAAC;EACDC,IAAI,GAAG;IACH,OAAO;MACHC,IAAI,EAAE,IAAI,CAACH;IACf;EACJ,CAAC;EAEDI,OAAO,EAAE;IACLC,YAAY,CAACF,IAAI,EAAE;MACf,OAAOA,IAAI,CAACG,QAAO,GAAIH,IAAI,CAACI,OAAO,CAACC,KAAI;IAC5C,CAAC;IACDC,iBAAiB,CAACN,IAAI,EAAE;MACpBA,IAAI,CAACG,QAAO,IAAK;MACjB,IAAIH,IAAI,CAACG,QAAO,KAAM,CAAC,EAAE;QACrB,IAAI,CAACI,KAAK,CAAC,gBAAgB,EAAEP,IAAI;MACrC;MACA,IAAI,CAACQ,UAAU,EAAC;IACpB,CAAC;IACDC,iBAAiB,CAACT,IAAI,EAAE;MACpBA,IAAI,CAACG,QAAO,IAAK;MACjB,IAAI,CAACK,UAAU,EAAC;IACpB,CAAC;IACDA,UAAU,GAAG;MACTE,YAAY,CAACC,OAAO,CAAC,MAAM,EAAEC,IAAI,CAACC,SAAS,CAAC,IAAI,CAACC,MAAM,CAACC,KAAK,CAACC,IAAI,CAAC;IACvE,CAAC;IACDC,cAAc,CAACjB,IAAI,EAAE;MACjB,IAAI,CAACO,KAAK,CAAC,gBAAgB,EAAEP,IAAI;MACjC,IAAI,CAACQ,UAAU,EAAC;IACpB;EACJ;AACJ","names":["name","props","initialItem","Object","data","item","methods","getItemTotal","quantity","product","price","decrementQuantity","$emit","updateCart","incrementQuantity","localStorage","setItem","JSON","stringify","$store","state","cart","removeFromCart"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\components\\CartItem.vue"],"sourcesContent":["<template>\r\n    <tr>\r\n    <td><router-link :to=\"item.product.get_absolute_url\" >{{ item.product.name }}</router-link></td>\r\n    <td>${{ item.product.price }}</td>\r\n    <td>\r\n        <a @click=\"decrementQuantity(item)\"><i class=\"fas fa-minus\"></i></a>\r\n        {{ item.quantity }}\r\n        <a @click=\"incrementQuantity(item)\"><i class=\"fas fa-plus\"></i></a>\r\n    </td>\r\n    <td>${{ getItemTotal(item).toFixed(2) }}</td>\r\n\r\n    <td>\r\n        <a class=\"text-danger\" @click=\"removeFromCart(item)\"><i class=\"fas fa-trash fa-lg\"></i></a>\r\n    </td>\r\n</tr>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n    name: 'CartItem',\r\n    props: {\r\n        initialItem: Object\r\n    },\r\n    data() {\r\n        return {\r\n            item: this.initialItem\r\n        }\r\n    },\r\n   \r\n    methods: {\r\n        getItemTotal(item) {\r\n            return item.quantity * item.product.price\r\n        },\r\n        decrementQuantity(item) {\r\n            item.quantity -= 1\r\n            if (item.quantity === 0) {\r\n                this.$emit('removeFromCart', item)\r\n            }\r\n            this.updateCart()\r\n        },\r\n        incrementQuantity(item) {\r\n            item.quantity += 1\r\n            this.updateCart()\r\n        },\r\n        updateCart() {\r\n            localStorage.setItem('cart', JSON.stringify(this.$store.state.cart))\r\n        },\r\n        removeFromCart(item) {\r\n            this.$emit('removeFromCart', item)\r\n            this.updateCart()\r\n        },\r\n    },\r\n}\r\n</script>\r\n<style scoped>\r\n.fas:hover{\r\n    cursor: pointer;\r\n}\r\n</style>"]},"metadata":{},"sourceType":"module","externalDependencies":[]}