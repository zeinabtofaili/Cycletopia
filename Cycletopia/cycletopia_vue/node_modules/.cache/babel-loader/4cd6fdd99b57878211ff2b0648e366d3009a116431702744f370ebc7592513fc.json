{"ast":null,"code":"import axios from 'axios';\nimport { toast } from 'vue3-toastify';\nimport 'vue3-toastify/dist/index.css';\nexport default {\n  name: 'UserBikes',\n  props: {\n    bike: Object\n  },\n  setup() {\n    const notify = () => {\n      toast(\"Delete bike successful. Please refresh the page to view changes.\", {\n        autoClose: 1000,\n        position: 'bottom-right',\n        type: 'success'\n      }); // ToastOptions\n    };\n\n    return {\n      notify\n    };\n  },\n  methods: {\n    deleteBike(id) {\n      axios.delete('/api/v1/delete-bike/' + id).then(response => {\n        console.log(\"Delete successful.\");\n        this.notify();\n      }).catch(error => {\n        console.log(error);\n      });\n    }\n  }\n};","map":{"version":3,"mappings":"AAqBA,OAAOA,KAAI,MAAO,OAAM;AACxB,SAASC,KAAI,QAAS,eAAe;AACrC,OAAO,8BAA8B;AAErC,eAAe;EACXC,IAAI,EAAE,WAAW;EACjBC,KAAK,EAAE;IACHC,IAAI,EAAEC;EACV,CAAC;EACDC,KAAK,GAAG;IACJ,MAAMC,MAAK,GAAI,MAAM;MACjBN,KAAK,CAAC,kEAAkE,EAAE;QACtEO,SAAS,EAAE,IAAI;QACfC,QAAQ,EAAE,cAAc;QACxBC,IAAI,EAAE;MACV,CAAC,CAAC,EAAE;IACR;;IACA,OAAO;MAAEH;IAAO,CAAC;EACrB,CAAC;EACDI,OAAO,EAAE;IACLC,UAAU,CAACC,EAAE,EAAE;MAEXb,KAAK,CAACc,MAAM,CAAC,sBAAsB,GAAED,EAAE,EAClCE,IAAI,CAACC,QAAO,IAAK;QACdC,OAAO,CAACC,GAAG,CAAC,oBAAoB;QAChC,IAAI,CAACX,MAAM,EAAE;MACjB,CAAC,EACAY,KAAK,CAACC,KAAI,IAAK;QACZH,OAAO,CAACC,GAAG,CAACE,KAAK;MACrB,CAAC;IACT;EACJ;AACJ","names":["axios","toast","name","props","bike","Object","setup","notify","autoClose","position","type","methods","deleteBike","id","delete","then","response","console","log","catch","error"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\components\\MyBikes.vue"],"sourcesContent":["<template>\r\n    <tr>\r\n        <td class=\"ms-3\">\r\n            <img v-bind:src=\"bike.get_thumbnail\" alt=\"\" style=\"width: 45px; height: 45px\" />\r\n        </td>\r\n        <td>\r\n            <div class=\"\">\r\n                <p class=\"fw-bold mb-1\">{{ bike.name }}</p>\r