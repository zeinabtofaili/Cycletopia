{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'Product',\n  data() {\n    return {\n      product: {},\n      quantity: 1\n    };\n  },\n  mounted() {\n    this.getProduct();\n  },\n  methods: {\n    async getProduct() {\n      // this.$store.commit('setIsLoading', true)\n\n      const category_slug = this.$route.params.category_slug;\n      const product_slug = this.$route.params.product_slug;\n      await axios.get(`/api/v1/products/${category_slug}/${product_slug}`).then(response => {\n        this.product = response.data;\n        document.title = this.product.name + ' | Djackets';\n      }).catch(error => {\n        console.log(error);\n      });\n\n      // this.$store.commit('setIsLoading', false)\n    }\n    // addToCart() {\n    //     if (isNaN(this.quantity) || this.quantity < 1) {\n    //         this.quantity = 1\n    //     }\n\n    //     const item = {\n    //         product: this.product,\n    //         quantity: this.quantity\n    //     }\n\n    //     this.$store.commit('addToCart', item)\n\n    //     toast({\n    //         message: 'The product was added to the cart',\n    //         type: 'is-success',\n    //         dismissible: true,\n    //         pauseOnHover: true,\n    //         duration: 2000,\n    //         position: 'bottom-right',\n    //     })\n    // }\n  }\n};","map":{"version":3,"mappings":"AAqDA,OAAOA,KAAI,MAAO,OAAM;AAExB,eAAe;EACXC,IAAI,EAAE,SAAS;EACfC,IAAI,GAAG;IACH,OAAO;MACHC,OAAO,EAAE,CAAC,CAAC;MACXC,QAAQ,EAAE;IACd;EACJ,CAAC;EACDC,OAAO,GAAG;IACN,IAAI,CAACC,UAAU,EAAC;EACpB,CAAC;EACDC,OAAO,EAAE;IACL,MAAMD,UAAU,GAAG;MACf;;MAEA,MAAME,aAAY,GAAI,IAAI,CAACC,MAAM,CAACC,MAAM,CAACF,aAAY;MACrD,MAAMG,YAAW,GAAI,IAAI,CAACF,MAAM,CAACC,MAAM,CAACC,YAAW;MAEnD,MAAMX,KAAI,CACLY,GAAG,CAAE,oBAAmBJ,aAAc,IAAGG,YAAa,EAAC,EACvDE,IAAI,CAACC,QAAO,IAAK;QACd,IAAI,CAACX,OAAM,GAAIW,QAAQ,CAACZ,IAAG;QAE3Ba,QAAQ,CAACC,KAAI,GAAI,IAAI,CAACb,OAAO,CAACF,IAAG,GAAI,aAAY;MACrD,CAAC,EACAgB,KAAK,CAACC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAG