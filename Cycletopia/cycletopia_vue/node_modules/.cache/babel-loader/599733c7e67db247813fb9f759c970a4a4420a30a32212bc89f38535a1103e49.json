{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'PlaceView',\n  data() {\n    return {\n      place: {}\n    };\n  },\n  mounted() {\n    this.getPlace();\n  },\n  methods: {\n    async getPlace() {\n      this.$store.commit('setIsLoading', true);\n      const place_slug = this.$route.params.place_slug;\n      await axios.get(`/api/v1/cycling-places/${place_slug}`).then(response => {\n        this.place = response.data;\n        document.title = this.place.name + ' | Cycletopia';\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    }\n  }\n};","map":{"version":3,"mappings":"AAsCA,OAAOA,KAAI,MAAO,OAAM;AACxB,eAAe;EACXC,IAAI,EAAE,WAAW;EACjBC,IAAI,GAAG;IACH,OAAO;MACHC,KAAK,EAAE,CAAC;IACZ;EACJ,CAAC;EACDC,OAAO,GAAG;IACN,IAAI,CAACC,QAAQ,EAAE;EACnB,CAAC;EACDC,OAAO,EAAE;IACL,MAAMD,QAAQ,GAAG;MACb,IAAI,CAACE,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,IAAI;MACvC,MAAMC,UAAS,GAAI,IAAI,CAACC,MAAM,CAACC,MAAM,CAACF,UAAS;MAC/C,MAAMT,KAAI,CACLY,GAAG,CAAE,0BAAyBH,UAAW,EAAC,EAC1CI,IAAI,CAACC,QAAO,IAAK;QACd,IAAI,CAACX,KAAI,GAAIW,QAAQ,CAACZ,IAAG;QAEzBa,QAAQ,CAACC,KAAI,GAAI,IAAI,CAACb,KAAK,CAACF,IAAG,GAAI,eAAc;MACrD,CAAC,EACAgB,KAAK,CAACC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAG,CAACF,KAAK;MACrB,CAAC;MAEL,IAAI,CAACX,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,KAAK;IAE5C;EACJ;AAEJ","names":["axios","name","data","place","mounted","getPlace","methods","$store","commit","place_slug","$route","params","get","then","response","document","title","catch","error","console","log"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\views\\PlaceView.vue"],"sourcesContent":["<template>\r\n    <div class=\"container\">\r\n        <div class=\"row\">\r\n            <div class=\"col-md shadow p-3 mb-5 bg-body rounded\">\r\n                <div class=\"row\">\r\n                    <div id=\"myDiv\" class=\"col-md d-flex justify-content-center text-center\">\r\n                        <h1>{{ place.name }} </h1>\r\n                    </div>\r\n                </div>\r\n\r\n                <div class=\"row\" style=\"margin-top:5%;\">\r\n                    <div class=\"col-md d-flex justify-content-center align-items-center\">\r\n                        <h6>{{ place.description }}</h6>\r\n                    </div>\r\n                    <div class=\"row\" style=\"margin-top:5%;\">\r\n                        <div class=\"col-md d-flex justify-content-center\">\r\n                            <img style=\"width:90%;\" v-bind:src=\"place.get_image\" alt=\"Cycling place image\">\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n\r\n            </div>\r\n            <div class=\"col-md shadow p-3 ml-4 mb-5 bg-body rounded \">\r\n                <h4>Location on map:</h4>\r\n                <div class=\"row\" style=\"margin-top:2%;\">\r\n\r\n                    <div class=\"col-md d-flex justify-content-center\">\r\n                        <iframe v-bind:src=\"place.map_url\" width=\"80%\" height=\"250\" allowfullscreen\r\n                            loading=\"lazy\"></iframe>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n    </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios'\r\nexport default {\r\n    name: 'PlaceView',\r\n    data() {\r\n        return {\r\n            place: {}\r\n        }\r\n    },\r\n    mounted() {\r\n        this.getPlace();\r\n    },\r\n    methods: {\r\n        async getPlace() {\r\n            this.$store.commit('setIsLoading', true)\r\n            const place_slug = this.$route.params.place_slug\r\n            await axios\r\n                .get(`/api/v1/cycling-places/${place_slug}`)\r\n                .then(response => {\r\n                    this.place = response.data\r\n\r\n                    document.title = this.place.name + ' | Cycletopia'\r\n                })\r\n                .catch(error => {\r\n                    console.log(error)\r\n                })\r\n\r\n            this.$store.commit('setIsLoading', false)\r\n\r\n        },\r\n    }\r\n\r\n}\r\n\r\n</script>\r\n<style scoped>\r\n\r\n</style>"]},"metadata":{},"sourceType":"module","externalDependencies":[]}