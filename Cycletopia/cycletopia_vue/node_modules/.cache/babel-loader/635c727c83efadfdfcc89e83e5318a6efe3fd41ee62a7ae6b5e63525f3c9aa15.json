{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from 'axios';\nimport OrderSummary from '@/components/OrderSummary.vue';\nexport default {\n  name: 'MyAccountView',\n  components: {\n    OrderSummary\n  },\n  data() {\n    return {\n      orders: []\n    };\n  },\n  mounted() {\n    document.title = 'My account | Cycletopia';\n    this.getMyOrders();\n  },\n  methods: {\n    logout() {\n      axios.defaults.headers.common[\"Authorization\"] = \"\";\n      localStorage.removeItem(\"token\");\n      localStorage.removeItem(\"userid\");\n      localStorage.removeItem(\"username\");\n      this.$store.commit('removeToken');\n      this.$router.push('/');\n    },\n    async getMyOrders() {\n      this.$store.commit('setIsLoading', true);\n      await axios.get('/api/v1/orders/').then(response => {\n        this.orders = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    }\n  }\n};","map":{"version":3,"mappings":";AAiBA,OAAOA,KAAI,MAAO,OAAM;AAExB,OAAOC,YAAW,MAAO,+BAA8B;AAEvD,eAAe;EACXC,IAAI,EAAE,eAAe;EACrBC,UAAU,EAAE;IACRF;EACJ,CAAC;EACDG,IAAI,GAAG;IACH,OAAO;MACHC,MAAM,EAAE;IACZ;EACJ,CAAC;EACDC,OAAO,GAAG;IACNC,QAAQ,CAACC,KAAI,GAAI,yBAAwB;IAEzC,IAAI,CAACC,WAAW,EAAC;EACrB,CAAC;EACDC,OAAO,EAAE;IACLC,MAAM,GAAG;MACLX,KAAK,CAACY,QAAQ,CAACC,OAAO,CAACC,MAAM,CAAC,eAAe,IAAI,EAAC;MAElDC,YAAY,CAACC,UAAU,CAAC,OAAO;MAC/BD,YAAY,CAACC,UAAU,CAAC,QAAQ;MAChCD,YAAY,CAACC,UAAU,CAAC,UAAU;MAElC,IAAI,CAACC,MAAM,CAACC,MAAM,CAAC,aAAa;MAEhC,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,GAAG;IACzB,CAAC;IACD,MAAMX,WAAW,GAAG;MAChB,IAAI,CAACQ,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,IAAI;MAEvC,MAAMlB,KAAI,CACLqB,GAAG,CAAC,iBAAiB,EACrBC,IAAI,CAACC,QAAO,IAAK;QACd,IAAI,CAAClB,MAAK,GAAIkB,QAAQ,CAACnB,IAAG;MAC9B,CAAC,EACAoB,KAAK,CAACC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAG,CAACF,KAAK;MACrB,CAAC;MAEL,IAAI,CAACR,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,KAAK;IAC5C;EACJ;AACJ","names":["axios","OrderSummary","name","components","data","o