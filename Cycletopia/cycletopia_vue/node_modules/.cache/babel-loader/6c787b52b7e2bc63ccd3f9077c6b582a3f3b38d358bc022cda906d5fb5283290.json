{"ast":null,"code":"import axios from 'axios';\nimport { toast } from 'vue3-toastify';\nimport 'vue3-toastify/dist/index.css';\nexport default {\n  name: 'Product',\n  setup() {\n    const notify = () => {\n      toast(\"The product was added to the cart!\", {\n        autoClose: 2000,\n        position: 'bottom-right',\n        type: 'success'\n      }); // ToastOptions\n    };\n\n    return {\n      notify\n    };\n  },\n  data() {\n    return {\n      product: {},\n      quantity: 1\n    };\n  },\n  mounted() {\n    this.getProduct();\n  },\n  methods: {\n    async getProduct() {\n      // this.$store.commit('setIsLoading', true)\n\n      const category_slug = this.$route.params.category_slug;\n      const product_slug = this.$route.params.product_slug;\n      await axios.get(`/api/v1/products/${category_slug}/${product_slug}`).then(response => {\n        this.product = response.data;\n        document.title = this.product.name + ' | Cycletopia';\n        if (this.product.color != null) {\n          document.getElementById('circle').style.color = this.product.color;\n          if (document.getElementById('circle').style.color.toLowerCase() != this.product.color.toLowerCase()) {\n            document.getElementById('circle').style.display = 'none';\n          }\n        }\n      }).catch(error => {\n        console.log(error);\n      });\n\n      // this.$store.commit('setIsLoading', false)\n    },\n\n    addToCart() {\n      if (isNaN(this.quantity) || this.quantity < 1) {\n        this.quantity = 1;\n      }\n      const item = {\n        product: this.product,\n        quantity: this.quantity\n      };\n      this.$store.commit('addToCart', item);\n    }\n  }\n};","map":{"version":3,"mappings":"AA4DA,OAAOA,KAAI,MAAO,OAAM;AACxB,SAASC,KAAI,QAAS,eAAe;AACrC,OAAO,8BAA8B;AAErC,eAAe;EACXC,IAAI,EAAE,SAAS;EACfC,KAAK,GAAG;IACJ,MAAMC,MAAK,GAAI,MAAM;MACjBH,KAAK,CAAC,oCAAoC,EAAE;QACxCI,SAAS,EAAE,IAAI;QACfC,QAAQ,EAAE,cAAc;QACxBC,IAAI,EAAE;MACV,CAAC,CAAC,EAAE;IACR;;IACA,OAAO;MAAEH;IAAO,CAAC;EACrB,CAAC;EACDI,IAAI,GAAG;IACH,OAAO;MACHC,OAAO,EAAE,CAAC,CAAC;MACXC,QAAQ,EAAE;IACd;EACJ,CAAC;EACDC,OAAO,GAAG;IACN,IAAI,CAACC,UAAU,EAAC;EACpB,CAAC;EACDC,OAAO,EAAE;IACL,MAAMD,UAAU,GAAG;MACf;;MAEA,MAAME,aAAY,GAAI,IAAI,CAACC,MAAM,CAACC,MAAM,CAACF,aAAY;MACrD,MAAMG,YAAW,GAAI,IAAI,CAACF,MAAM,CAACC,MAAM,CAACC,YAAW;MAEnD,MAAMjB,KAAI,CACLkB,GAAG,CAAE,oBAAmBJ,aAAc,IAAGG,YAAa,EAAC,EACvDE,IAAI,CAACC,QAAO,IAAK;QACd,IAAI,CAACX,OAAM,GAAIW,QAAQ,CAACZ,IAAG;QAE3Ba,QAAQ,CAACC,KAAI,GAAI,IAAI,CAACb,OAAO,CAACP,IAAG,GAAI,eAAc;QACnD,IAAI,IAAI,CAACO,OAAO,CAACc,KAAI,IAAK,IAAI,EAAE;UAC5BF,QAAQ,CAACG,cAAc,CAAC,QAAQ,CAAC,CAACC,KAAK,CAACF,KAAI,GAAI,IAAI,CAACd,OAAO,CAACc,KAAK;UAClE,IAAIF,QAAQ,CAACG,cAAc,CAAC,QAAQ,CAAC,CAACC,KAAK,CAACF,KAAK,CAACG,WAAW,EAAC,IAAK,IAAI,CAACjB,OAAO,CAACc,KAAK,CAACG,WAAW,EAAE,EAAE;YACjGL,QAAQ,CAACG,cAAc,CAAC,QAAQ,CAAC,CAACC,KAAK,CAACE,OAAM,GAAI,MAAM;UAC5D;QACJ;MACJ,CAAC,EACAC,KAAK,CAACC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAG,CAACF,KAAK;MACrB,CAAC;;MAEL;IACJ,CAAC;;IACDG,SAAS,GAAG;MACR,IAAIC,KAAK,CAAC,IAAI,CAACvB,QAAQ,KAAK,IAAI,CAACA,QAAO,GAAI,CAAC,EAAE;QAC3C,IAAI,CAACA,QAAO,GAAI;MACpB;MAEA,MAAMwB,IAAG,GAAI;QACTzB,OAAO,EAAE,IAAI,CAACA,OAAO;QACrBC,QAAQ,EAAE,IAAI,CAACA;MACnB;MAEA,IAAI,CAACyB,MAAM,CAACC,MAAM,CAAC,WAAW,EAAEF,IAAI;IAExC;EACJ;AACJ","names":["axios","toast","name","setup","notify","autoClose","position","type","data","product","quantity","mounted","getProduct","methods","category_slug","$route","params","product_slug","get","then","response","document","title","color","getElementById","style","toLowerCase","display","catch","error","console","log","addToCart","isNaN","item","$store","commit"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\views\\ProductView.vue"],"sourcesContent":["<template>\r\n    <div class=\"container mt-5 mb-5\">\r\n        <div class=\"row d-flex justify-content-center\">\r\n            <div class=\"col-md-10\">\r\n                <div class=\"card\">\r\n                    <div class=\"row\">\r\n                        <div class=\"col-md-6\">\r\n                            <div class=\"images p-3\">\r\n                                <div class=\"text-center p-4\"> <img v-bind:src=\"product.get_image\" width=\"250\" /> </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"col-md-6\">\r\n                            <div class=\"product p-4\">\r\n                                <div class=\"mt-4 mb-3\">\r\n                                    <h5 class=\"text-uppercase\">{{ product.name }}</h5>\r\n                                    <div class=\"price d-flex flex-row align-items-center\"> <span class=\"act-price\">${{\r\n                                        product.price\r\n                                    }}</span>\r\n\r\n                                    </div>\r\n                                </div>\r\n                                <p class=\"about\">{{ product.description }}\r\n                                </p>\r\n                                <div class=\"sizes mt-5\">\r\n                                    <h6 class=\"text-uppercase\">Size: {{ product.size }}</h6>\r\n                                </div>\r\n                                <div class=\"sizes mt-5\">\r\n                                    <h6 class=\"text-uppercase\" v-if=\"product.grouping !== null\">Category: {{\r\n                                        product.grouping\r\n                                    }}</h6>\r\n                                </div>\r\n                                <div class=\"sizes mt-5\">\r\n                                    <h6 class=\"text-uppercase\" v-if=\"product.gender !== null\">Gender: {{\r\n                                        product.gender\r\n                                    }}</h6>\r\n                                </div>\r\n                                <div class=\"sizes mt-5\">\r\n                                    <h6 class=\"text-uppercase\" v-if=\"product.color !== null\">Color: <i\r\n                                            class=\"fa-solid fa-circle fa-border\" id=\"circle\"></i> {{\r\n                                                product.color\r\n                                            }}</h6>\r\n                                </div>\r\n                                <div class=\"cart mt-4 align-items-center\">\r\n                                    <div class=\"input-group mb-3\">\r\n                                        <input type=\"number\" class=\"form-control\" min=\"1\" v-model=\"quantity\">\r\n                                        <button class=\"btn btn-dark text-uppercase mr-2 px-4\" @click=\"addToCart(); notify();\">Add to\r\n                                            cart</button>\r\n\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios'\r\nimport { toast } from 'vue3-toastify';\r\nimport 'vue3-toastify/dist/index.css';\r\n\r\nexport default {\r\n    name: 'Product',\r\n    setup() {\r\n        const notify = () => {\r\n            toast(\"The product was added to the cart!\", {\r\n                autoClose: 2000,\r\n                position: 'bottom-right',\r\n                type: 'success',\r\n            }); // ToastOptions\r\n        }\r\n        return { notify };\r\n    },\r\n    data() {\r\n        return {\r\n            product: {},\r\n            quantity: 1\r\n        }\r\n    },\r\n    mounted() {\r\n        this.getProduct()\r\n    },\r\n    methods: {\r\n        async getProduct() {\r\n            // this.$store.commit('setIsLoading', true)\r\n\r\n            const category_slug = this.$route.params.category_slug\r\n            const product_slug = this.$route.params.product_slug\r\n\r\n            await axios\r\n                .get(`/api/v1/products/${category_slug}/${product_slug}`)\r\n                .then(response => {\r\n                    this.product = response.data\r\n\r\n                    document.title = this.product.name + ' | Cycletopia'\r\n                    if (this.product.color != null) {\r\n                        document.getElementById('circle').style.color = this.product.color;\r\n                        if (document.getElementById('circle').style.color.toLowerCase() != this.product.color.toLowerCase()) {\r\n                            document.getElementById('circle').style.display = 'none';\r\n                        }\r\n                    }\r\n                })\r\n                .catch(error => {\r\n                    console.log(error)\r\n                })\r\n\r\n            // this.$store.commit('setIsLoading', false)\r\n        },\r\n        addToCart() {\r\n            if (isNaN(this.quantity) || this.quantity < 1) {\r\n                this.quantity = 1\r\n            }\r\n\r\n            const item = {\r\n                product: this.product,\r\n                quantity: this.quantity\r\n            }\r\n\r\n            this.$store.commit('addToCart', item)\r\n\r\n        }\r\n    }\r\n}\r\n</script>"]},"metadata":{},"sourceType":"module","externalDependencies":[]}