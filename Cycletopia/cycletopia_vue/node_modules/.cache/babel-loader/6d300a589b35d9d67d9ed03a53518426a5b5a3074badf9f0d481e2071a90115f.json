{"ast":null,"code":"export default {\n  mounted() {\n    document.title = 'About | Cycletopia';\n  }\n};","map":{"version":3,"mappings":"AAmDA,eAAe;EAEbA,OAAO,GAAG;IACRC,QAAQ,CAACC,KAAI,GAAI,oBAAmB;EACtC;AACF","names":["mounted","document","title"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\views\\AboutView.vue"],"sourcesContent":["<template>\n  <div class=\"about\">\n    <p>This is an about page</p>\n  </div>\n\n <!-- Section 1 - Hero -->\n <section id=\"hero\" class=\"bg-dark text-white py-5\">\n        <div class=\"container\">\n            <div class=\"row\">\n                <div class=\"col-md-8\">\n                    <h1 class=\"display-4 mb-3\">Welcome to Cycletopia!</h1>\n                    <p class=\"lead mb-3\">\"The bicycle is a curious vehicle. Its passenger is its engine.\" - John Howard</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Section 2 - Introduction -->\n    <section id=\"intro\" class=\"py-5\">\n        <div class=\"container\">\n            <div class=\"row\">\n                <div class=\"col-md-6\">\n                    <h2 class=\"mb-3\">Introduction</h2>\n                    <p>Cycletopia was founded with a simple mission: to promote the use of bicycles as a clean, cheap, and healthy substitute for traditional transportation methods in Lebanon. With the transport sector being the primary cause of air pollution, which is causing the death of thousands of individuals annually and costing our economy billions of dollars per year, we believe that bicycles can make a significant difference.</p>\n                    <p>Through our website, users can buy, rent, and donate bicycles, as well as purchase cycling clothing and components. We also offer a range of services, including event registration, professional training, and bike repairs. Our ultimate goal is to make cycling accessible and enjoyable for everyone in Lebanon.</p>\n                </div>\n                <div class=\"col-md-6\">\n                    <img src=\"https://via.placeholder.com/600x400.png?text=Image+Placeholder\" class=\"img-fluid rounded\" alt=\"Placeholder Image\">\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Section 3 - Bike Rentals -->\n    <section id=\"rentals\" class=\"bg-light py-5\">\n        <div class=\"container\">\n            <div class=\"row\">\n                <div class=\"col-md-6\">\n                    <img src=\"https://via.placeholder.com/600x400.png?text=Image+Placeholder\" class=\"img-fluid rounded\" alt=\"Placeholder Image\">\n                </div>\n                <div class=\"col-md-6\">\n                    <h2 class=\"mb-3\">Bike Rentals</h2>\n                    <p>At Cycletopia, we offer a wide selection of bikes for rent, including mountain bikes, road bikes, and more. Our rental rates are affordable and competitive, and we offer flexible rental periods to fit your needs.</p>\n                    <p>Whether you're a seasoned cyclist or just starting out, we have the perfect bike for you. Our friendly and knowledgeable staff can help you choose the right bike and provide tips on where to ride in Lebanon.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n</template>\n\n<script>\nexport default {\n\n  mounted() {\n    document.title = 'About | Cycletopia'\n  },\n}\n</script>\n"]},"metadata":{},"sourceType":"module","externalDependencies":[]}