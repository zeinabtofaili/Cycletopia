{"ast":null,"code":"export default {\n  mounted() {\n    document.title = 'About | Cycletopia';\n  }\n};","map":{"version":3,"mappings":"AA0NA,eAAe;EAEbA,OAAO,GAAG;IACRC,QAAQ,CAACC,KAAI,GAAI,oBAAmB;EACtC;AACF","names":["mounted","document","title"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\views\\AboutView.vue"],"sourcesContent":["<template>\n  <!-- <div class=\"container-fluid px-0\">\n    <div class=\"about-section bg-light py-5\">\n      <div class=\"container\">\n        <div class=\"row align-items-center justify-content-center\">\n          <div class=\"col-md-8 text-center\">\n            <h1 class=\"display-4 mb-3\">Welcome to Cycletopia</h1>\n            <p class=\"lead mb-4\">\"Zero emissions, Zero excuses\"</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"container py-5\">\n      <div class=\"row align-items-center justify-content-center\">\n        <div class=\"col-md-8\">\n          <div class=\"card border-0 bg-transparent text-center\">\n            <div class=\"card-body\">\n              <h2 class=\"card-title mb-4\">Our Mission</h2>\n              <p class=\"card-text lead\">At Cycletopia, we believe in the power of cycling to transform communities, reduce\n                pollution, and promote a healthier lifestyle. Our mission is to make cycling accessible and affordable for\n                everyone in Lebanon, and to inspire a culture of cycling that supports a sustainable and vibrant future.\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"bg-white py-5\">\n      <div class=\"container\">\n        <div class=\"row\">\n          <div class=\"col-md-6\">\n            <div class=\"card border-0 bg-transparent text-center\">\n              <div class=\"card-body\">\n                <h2 class=\"card-title mb-4\">Rentals &amp; Sales</h2>\n                <p class=\"card-text lead\">Whether you're looking to rent a bike for a day, buy a new or used bike, or sell\n                  your old one, Cycletopia has you covered. With a wide selection of bikes, cycling clothing, and\n                  accessories, we're your one-stop-shop for all your cycling needs.</p>\n              </div>\n            </div>\n          </div>\n          <div class=\"col-md-6\">\n            <img src=\"@/assets/bike3.jpg\" class=\"img-fluid rounded\">\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"container py-5\">\n      <div class=\"row\">\n        <div class=\"col-md-6\">\n          <img src=\"@/assets/bike4.jpg\" class=\"img-fluid rounded\">\n        </div>\n        <div class=\"col-md-6\">\n          <div class=\"card border-0 bg-transparent text-center\">\n            <div class=\"card-body\">\n              <h2 class=\"card-title mb-4\">Events &amp; Training</h2>\n              <p class=\"card-text lead\">Cycletopia hosts a variety of cycling events throughout the year, from leisurely\n                group rides to more competitive races. We also offer training sessions for cyclists of all levels, led by\n                experienced professionals who can help you improve your skills and reach your cycling goals.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"bg-white py-5\">\n      <div class=\"container\">\n        <div class=\"row\">\n          <div class=\"col-md-6\">\n            <div class=\"card border-0 bg-transparent text-center\">\n              <div class=\"card-body\">\n                <h2 class=\"card-title mb-4\">Bicycle Donation Program</h2>\n                <p class=\"card-text lead\">Cycletopia is committed to promoting cycling as a means of transportation and\n                  recreation for all, regardless of income level. That's why we've launched our Bicycle Donation Program,\n                  which collects and refurbishes used bikes to give to individuals and families in need. Help us make a\n                  difference by donating your old bike today.</p>\n              </div>\n            </div>\n          </div>\n          <div class=\"col-md-6\">\n            <img src=\"@/assets/bike5.jpg\" class=\"img-fluid rounded\">\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"container py-5\">\n      <div class=\"row\">\n        <div class=\"col-md-6\">\n          <img src=\"@/assets/bike2.jpg\" class=\"img-fluid rounded\">\n        </div>\n        <div class=\"col-md-6\">\n          <div class=\"card border-0 bg-transparent text-center\">\n            <div class=\"card-body\">\n              <h2 class=\"card-title mb-4\">Join the Cycletopia Community</h2>\n              <p class=\"card-text lead\">Cycletopia is more than just a bike shop - it's a community of cyclists who are\n                passionate about making a positive impact on the world. Join us for rides, events, and social gatherings,\n                and connect with like-minded individuals who share your love of cycling.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div> -->\n\n\n  <div class=\"container-fluid px-0\">\n  <div class=\"about-section bg-light py-5\">\n    <div class=\"container\">\n      <div class=\"row align-items-center justify-content-center\">\n        <div class=\"col-md-8 text-center\">\n          <h1 class=\"display-4 mb-3\">Welcome to Cycletopia</h1>\n          <p class=\"lead mb-4\">\"Ride a bike, save the planet\"</p>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"container py-5\">\n    <div class=\"row align-items-center justify-content-center\">\n      <div class=\"col-md-8\">\n        <div class=\"card border-0 bg-transparent text-center\">\n          <div class=\"card-body\">\n            <h2 class=\"card-title mb-4\">Our Mission</h2>\n            <p class=\"card-text lead\">At Cycletopia, we believe in the power of cycling to transform communities, reduce pollution, and promote a healthier lifestyle. Our mission is to make cycling accessible and affordable for everyone in Lebanon, and to inspire a culture of cycling that supports a sustainable and vibrant future.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"bg-white py-5\">\n    <div class=\"container\">\n      <div class=\"row\">\n        <div class=\"col-md-6\">\n          <div class=\"card border-0 bg-transparent text-center\">\n            <div class=\"card-body\">\n              <h2 class=\"card-title mb-4\">Rentals &amp; Sales</h2>\n              <p class=\"card-text lead\">Whether you're looking to rent a bike for a day, buy a new or used bike, or sell your old one, Cycletopia has you covered. With a wide selection of bikes, cycling clothing, and accessories, we're your one-stop-shop for all your cycling needs.</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"col-md-6\">\n          <div class=\"circular-img-container\">\n            <img src=\"@/assets/bike3.jpg\" class=\"circular-img\">\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"container py-5\">\n    <div class=\"row\">\n      <div class=\"col-md-6\">\n        <div class=\"circular-img-container\">\n          <img src=\"@/assets/bike2.jpg\" class=\"circular-img\">\n        </div>\n      </div>\n      <div class=\"col-md-6\">\n        <div class=\"card border-0 bg-transparent text-center\">\n          <div class=\"card-body\">\n            <h2 class=\"card-title mb-4\">Events &amp; Training</h2>\n            <p class=\"card-text lead\">Cycletopia hosts a variety of cycling events throughout the year, from leisurely group rides to more competitive races. We also offer training sessions for cyclists of all levels, led by experienced professionals who can help you improve your skills and reach your cycling goals.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"bg-white py-5\">\n    <div class=\"container\">\n      <div class=\"row\">\n        <div class=\"col-md-6\">\n          <div class=\"card border-0 bg-transparent text-center\">\n            <div class=\"card-body\">\n              <h2 class=\"card-title mb-4\">Bike Repair Services</h2>\n              <p class=\"card-text lead\">Cycletopia offers a full range of bike repair and maintenance services, from basic tune-ups to full overhauls. Our experienced mechanics can help you keep your bike in top condition, so you can enjoy a smooth and safe ride.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"container py-5\">\n    <div class=\"row\">\n      <div class=\"col-md-4\">\n        <div class=\"card border-0 bg-transparent text-center\">\n          <div class=\"card-body\">\n            <h2 class=\"card-title mb-4\">Eco-Friendly Shop</h2>\n            <p class=\"card-text lead\">At Cycletopia, we're committed to sustainability. That's why we use eco-friendly cleaning products, offer bike rentals and repairs instead of selling new bikes, and use renewable energy sources to power our shop. Join us in our mission to protect the planet!</p>\n          </div>\n        </div>\n      </div>\n      <div class=\"col-md-4\">\n        <div class=\"card border-0 bg-transparent text-center\">\n          <div class=\"card-body\">\n            <h2 class=\"card-title mb-4\">Join Our Community</h2>\n            <p class=\"card-text lead\">Cycletopia is more than just a bike shop - it's a community of like-minded individuals who share a passion for cycling and sustainable living. Join us for group rides, events, and workshops, and become a part of the Cycletopia family.</p>\n          </div>\n        </div>\n      </div>\n      <div class=\"col-md-4\">\n        <div class=\"card border-0 bg-transparent text-center\">\n          <div class=\"card-body\">\n            <h2 class=\"card-title mb-4\">Contact Us</h2>\n            <p class=\"card-text lead\">Have a question or need help with your bike? Don't hesitate to reach out to us. You can visit us in person at our shop, call us at (xxx) xxx-xxxx, or send us an email at info@cycletopia.com. We're always happy to hear from you!</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n</div>\n</template>\n\n<script>\nexport default {\n\n  mounted() {\n    document.title = 'About | Cycletopia'\n  },\n}\n</script>\n"]},"metadata":{},"sourceType":"module","externalDependencies":[]}