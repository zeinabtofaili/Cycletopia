{"ast":null,"code":"import axios from 'axios';\nexport default {\n  name: 'PlaceView',\n  data() {\n    return {\n      place: {}\n    };\n  },\n  mounted() {\n    this.getPlace();\n  },\n  methods: {\n    async getPlace() {\n      this.$store.commit('setIsLoading', true);\n      const place_slug = this.$route.params.place_slug;\n      await axios.get(`/api/v1/cycling-places/${place_slug}`).then(response => {\n        this.place = response.data;\n        document.title = this.place.name + ' | Cycletopia';\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n      const imageUrl = {\n        url: this.place.get_image\n      };\n      console.log(this.place.get_image);\n      document.getElementById(\"myDiv\").style.backgroundImage = \"url(\" + imageUrl.url + \")\";\n    }\n  }\n};","map":{"version":3,"mappings":"AA0BA,OAAOA,KAAI,MAAO,OAAM;AACxB,eAAe;EACXC,IAAI,EAAE,WAAW;EACjBC,IAAI,GAAG;IACH,OAAO;MACHC,KAAK,EAAE,CAAC;IACZ;EACJ,CAAC;EACDC,OAAO,GAAG;IACN,IAAI,CAACC,QAAQ,EAAE;EACnB,CAAC;EACDC,OAAO,EAAE;IACL,MAAMD,QAAQ,GAAG;MACb,IAAI,CAACE,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,IAAI;MACvC,MAAMC,UAAS,GAAI,IAAI,CAACC,MAAM,CAACC,MAAM,CAACF,UAAS;MAC/C,MAAMT,KAAI,CACLY,GAAG,CAAE,0BAAyBH,UAAW,EAAC,EAC1CI,IAAI,CAACC,QAAO,IAAK;QACd,IAAI,CAACX,KAAI,GAAIW,QAAQ,CAACZ,IAAG;QAEzBa,QAAQ,CAACC,KAAI,GAAI,IAAI,CAACb,KAAK,CAACF,IAAG,GAAI,eAAc;MACrD,CAAC,EACAgB,KAAK,CAACC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAG,CAACF,KAAK;MACrB,CAAC;MAEL,IAAI,CAACX,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,KAAK;MACxC,MAAMa,QAAO,GAAI;QAAEC,GAAG,EAAE,IAAI,CAACnB,KAAK,CAACoB;MAAU,CAAC;MAC9CJ,OAAO,CAACC,GAAG,CAAC,IAAI,CAACjB,KAAK,CAACoB,SAAS;MAChCR,QAAQ,CAACS,cAAc,CAAC,OAAO,CAAC,CAACC,KAAK,CAACC,eAAc,GAAI,MAAK,GAAIL,QAAQ,CAACC,GAAE,GAAI,GAAG;IACxF;EACJ;AAEJ","names":["axios","name","data","place","mounted","getPlace","methods","$store","commit","place_slug","$route","params","get","then","response","document","title","catch","error","console","log","imageUrl","url","get_im