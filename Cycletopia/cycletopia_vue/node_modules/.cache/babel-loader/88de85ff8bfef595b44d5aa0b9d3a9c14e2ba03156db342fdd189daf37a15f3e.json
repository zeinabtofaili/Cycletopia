{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from 'axios';\nexport default {\n  name: 'ScheduleAppointment',\n  data() {\n    return {\n      trainers: [],\n      bikeTypes: ['Mountain', 'Road', 'Electric'],\n      locations: ['Indoor', 'Outdoor'],\n      trainer: '',\n      bikeType: '',\n      location: '',\n      dateTime: ''\n    };\n  },\n  mounted() {\n    axios.get('/api/v1/trainers/').then(response => {\n      this.trainers = response.data;\n    }).catch(error => {\n      console.log(error);\n    });\n  },\n  methods: {\n    scheduleAppointment() {\n      const data = {\n        trainer: this.trainer,\n        bike_type: this.bikeType,\n        location: this.location,\n        date_time: this.dateTime\n      };\n      axios.post('/api/v1/schedule-appointment/', data).then(response => {\n        // Redirect to the appointments list page\n        this.$router.push('/appointments/');\n      }).catch(error => {\n        console.log(error);\n      });\n    }\n  }\n};","map":{"version":3,"mappings":";AAyBA,OAAOA,KAAI,MAAO,OAAO;AAEzB,eAAe;EACXC,IAAI,EAAE,qBAAqB;EAE3BC,IAAI,GAAG;IACH,OAAO;MACHC,QAAQ,EAAE,EAAE;MACZC,SAAS,EAAE,CAAC,UAAU,EAAE,MAAM,EAAE,UAAU,CAAC;MAC3CC,SAAS,EAAE,CAAC,QAAQ,EAAE,SAAS,CAAC;MAChCC,OAAO,EAAE,EAAE;MACXC,QAAQ,EAAE,EAAE;MACZC,QAAQ,EAAE,EAAE;MACZC,QAAQ,EAAE;IACd,CAAC;EACL,CAAC;EACDC,OAAO,GAAG;IACNV,KAAK,CAACW,GAAG,CAAC,mBAAmB,EACxBC,IAAI,CAACC,QAAO,IAAK;MACd,IAAI,CAACV,QAAO,GAAIU,QAAQ,CAACX,IAAI;IACjC,CAAC,EACAY,KAAK,CAACC,KAAI,IAAK;MACZC,OAAO,CAACC,GAAG,CAACF,KAAK,CAAC;IACtB,CAAC,CAAC;EACV,CAAC;EACDG,OAAO,EAAE;IACLC,mBAAmB,GAAG;MAClB,MAAMjB,IAAG,GAAI;QACTI,OAAO,EAAE,IAAI,CAACA,OAAO;QACrBc,SAAS,EAAE,IAAI,CAACb,QAAQ;QACxBC,QAAQ,EAAE,IAAI,CAACA,QAAQ;QACvBa,SAAS,EAAE,IAAI,CAACZ;MACpB,CAAC;MACDT,KAAK,CAACsB,IAAI,CAAC,+BAA+B,EAAEpB,IAAI,EAC3CU,IAAI,CAACC,QAAO,IAAK;QACd;QACA,IAAI,CAACU,OAAO,CAACC,IAAI,CAAC,gBAAgB,CAAC;MACvC,CAAC,EACAV,KAAK,CAACC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAG,CAACF,KAAK,CAAC;MACtB,CAAC,CAAC;IACV;EACJ;AACJ,CAAC","names":["axios","name","data","trainers","bikeTypes","locations","trainer","bikeType","location","dateTime","mounted","get","then","response","catch","error","console","log","methods","scheduleAppointment","bike_type","date_time","post","$router","push"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\views\\ScheduleAppointment.vue"],"sourcesContent":["<template>\r\n    <form @submit.prevent=\"scheduleAppointment\">\r\n        <label for=\"trainer\">Trainer:</label>\r\n        <select v-model=\"trainer\">\r\n            <option v-for=\"t in trainers\" :value=\"t.name\">{{ t.name }}</option>\r\n        </select>\r\n        <br>\r\n        <label for=\"bike_type\">Bike Type:</label>\r\n        <select v-model=\"bikeType\">\r\n            <option v-for=\"b in bikeTypes\" :value=\"b\">{{ b }}</option>\r\n        </select>\r\n        <br>\r\n        <label for=\"location\">Location:</label>\r\n        <select v-model=\"location\">\r\n            <option v-for=\"l in locations\" :value=\"l\">{{ l }}</option>\r\n        </select>\r\n        <br>\r\n        <label for=\"date_time\">Date and Time:</label>\r\n        <input type=\"datetime-local\" v-model=\"dateTime\">\r\n        <br>\r\n        <button type=\"submit\">Schedule Appointment</button>\r\n    </form>\r\n</template>\r\n  \r\n<script>\r\nimport axios from 'axios';\r\n\r\nexport default {\r\n    name: 'ScheduleAppointment',\r\n\r\n    data() {\r\n        return {\r\n            trainers: [],\r\n            bikeTypes: ['Mountain', 'Road', 'Electric'],\r\n            locations: ['Indoor', 'Outdoor'],\r\n            trainer: '',\r\n            bikeType: '',\r\n            location: '',\r\n            dateTime: '',\r\n        };\r\n    },\r\n    mounted() {\r\n        axios.get('/api/v1/trainers/')\r\n            .then(response => {\r\n                this.trainers = response.data;\r\n            })\r\n            .catch(error => {\r\n                console.log(error);\r\n            });\r\n    },\r\n    methods: {\r\n        scheduleAppointment() {\r\n            const data = {\r\n                trainer: this.trainer,\r\n                bike_type: this.bikeType,\r\n                location: this.location,\r\n                date_time: this.dateTime,\r\n            };\r\n            axios.post('/api/v1/schedule-appointment/', data)\r\n                .then(response => {\r\n                    // Redirect to the appointments list page\r\n                    this.$router.push('/appointments/');\r\n                })\r\n                .catch(error => {\r\n                    console.log(error);\r\n                });\r\n        },\r\n    },\r\n};\r\n</script>\r\n  "]},"metadata":{},"sourceType":"module","externalDependencies":[]}