{"ast":null,"code":"export default {\n  mounted() {\n    document.title = 'About | Cycletopia';\n  }\n};","map":{"version":3,"mappings":"AAuEA,eAAe;EAEbA,OAAO,GAAG;IACRC,QAAQ,CAACC,KAAI,GAAI,oBAAmB;EACtC;AACF","names":["mounted","document","title"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\views\\AboutView.vue"],"sourcesContent":["<template>\n  <div class=\"about\">\n    <p>This is an about page</p>\n  </div>\n\n\n\n  <div class=\"container my-5\">\n    <h1 class=\"text-center mb-5\">Welcome to Cycletopia</h1>\n    <div class=\"row\">\n      <div class=\"col-md-6\">\n        <div class=\"card mb-4\">\n          <img src=\"https://via.placeholder.com/500x300.png?text=Image+1\" class=\"card-img-top\" alt=\"...\">\n          <div class=\"card-body\">\n            <h5 class=\"card-title\">Our Mission</h5>\n            <p class=\"card-text\">At Cycletopia, our primary mission is to promote the use of bicycles as a clean, cheap,\n              and healthy alternative to traditional forms of transportation. We believe that cycling can help reduce air\n              pollution and improve the overall health and well-being of our community.</p>\n          </div>\n        </div>\n      </div>\n      <div class=\"col-md-6\">\n        <div class=\"card mb-4\">\n          <img src=\"https://via.placeholder.com/500x300.png?text=Image+2\" class=\"card-img-top\" alt=\"...\">\n          <div class=\"card-body\">\n            <h5 class=\"card-title\">Our Services</h5>\n            <p class=\"card-text\">Through Cycletopia, you can buy, rent, and sell new and used bicycles, as well as cycling\n              clothing and components. We also offer cycling events and training sessions, and accept donations of old\n              bicycles that we fix up and then sell or rent out at very low prices.</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"row\">\n        <div class=\"col-md-6\">\n          <div class=\"card mb-4\">\n            <img src=\"https://via.placeholder.com/500x300.png?text=Image+3\" class=\"card-img-top\" alt=\"...\">\n            <div class=\"card-body\">\n              <h5 class=\"card-title\">Our Impact</h5>\n              <p class=\"card-text\">We're committed to making a positive impact on the environment and our community. By\n                promoting cycling and reducing reliance on cars, we can help reduce air pollution and improve public\n                health. We're also proud to offer affordable options for people who might not otherwise be able to afford\n                a bicycle.</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"col-md-6\">\n          <div class=\"card mb-4\">\n            <img src=\"https://via.placeholder.com/500x300.png?text=Image+4\" class=\"card-img-top\" alt=\"...\">\n            <div class=\"card-body\">\n              <h5 class=\"card-title\">Get Involved</h5>\n              <p class=\"card-text\">We're always looking for volunteers, sponsors, and partners to help us achieve our\n                mission. Whether you're a cycling enthusiast or simply want to support a good cause, we welcome your\n                involvement. Contact us to learn more about how you can help.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n\n    <!-- Footer -->\n    <footer class=\"bg-light py-3\">\n      <div class=\"container text-center\">\n        <p class=\"mb-0\">&copy; 2023 Cycletopia. All rights reserved.</p>\n      </div>\n    </footer>\n    </div>\n</template>\n\n<script>\nexport default {\n\n  mounted() {\n    document.title = 'About | Cycletopia'\n  },\n}\n</script>\n"]},"metadata":{},"sourceType":"module","externalDependencies":[]}