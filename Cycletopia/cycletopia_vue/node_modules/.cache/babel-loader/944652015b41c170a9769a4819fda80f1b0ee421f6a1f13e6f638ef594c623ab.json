{"ast":null,"code":"import axios from 'axios';\nimport ProductCard from '@/components/ProductCard';\nexport default {\n  name: 'HomeView',\n  data() {\n    return {\n      latestProducts: []\n    };\n  },\n  components: {\n    ProductCard\n  },\n  mounted() {\n    this.getLatestProducts();\n    document.title = 'Home | Djackets';\n  },\n  methods: {\n    async getLatestProducts() {\n      // this.$store.commit('setIsLoading', true)\n      await axios.get('/api/v1/latest-products/').then(response => {\n        this.latestProducts = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      // this.$store.commit('setIsLoading', false)\n    }\n  }\n};","map":{"version":3,"mappings":"AA4BA,OAAOA,KAAI,MAAO,OAAM;AACxB,OAAOC,WAAU,MAAO,0BAAyB;AACjD,eAAe;EACbC,IAAI,EAAE,UAAU;EAChBC,IAAI,GAAG;IACL,OAAO;MACLC,cAAc,EAAE;IAClB;EACF,CAAC;EACDC,UAAU,EAAE;IACVJ;EACF,CAAC;EACDK,OAAO,GAAG;IACR,IAAI,CAACC,iBAAiB,EAAC;IACvBC,QAAQ,CAACC,KAAI,GAAI,iBAAgB;EACnC,CAAC;EACDC,OAAO,EAAE;IACP,MAAMH,iBAAiB,GAAG;MACxB;MACA,MAAMP,KAAI,CACPW,GAAG,CAAC,0BAA0B,EAC9BC,IAAI,CAACC,QAAO,IAAK;QAChB,IAAI,CAACT,cAAa,GAAIS,QAAQ,CAACV,IAAG;MACpC,CAAC,EACAW,KAAK,CAACC,KAAI,IAAK;QACdC,OAAO,CAACC,GAAG,CAACF,KAAK;MACnB,CAAC;MACH;IACF;EACF;AACF","names":["axios","ProductCard","name","data","latestProducts","components","mounted","getLatestProducts","document","title","methods","get","then","response","catch","error","console","log"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\views\\HomeView.vue"],"sourcesContent":["<template>\n  <div class=\"home\">\n    <div class=\"d-flex h-100 text-center\">\n      <div class=\"cover-container d-flex w-100 h-100 p-3 mx-auto flex-column\">\n\n        <main class=\"px-3\">\n          <h1>Welcome to Cycletopia</h1>\n          <p class=\"lead\">Zero waste, Zero excuses.</p>\n          <p>\n            <img src=\"@/assets/bicycle\">\n          </p>\n        </main>\n\n      </div>\n    </div>\n\n    <div class=\"column is-12\">\n      <h2 class=\"is-size-2 has-text-centered\">Latest products</h2>\n    </div>\n\n    <div class=\"flexbox\">\n      <ProductCard class=\"flex-item\" v-for=\"product in latestProducts\" v-bind:key=\"product.id\"\n        v-bind:product=\"product\" />\n    </div>\n  </div>\n</template>\n\n<script>\nimport axios from 'axios'\nimport ProductCard from '@/components/ProductCard'\nexport default {\n  name: 'HomeView',\n  data() {\n    return {\n      latestProducts: []\n    }\n  },\n  components: {\n    ProductCard\n  },\n  mounted() {\n    this.getLatestProducts()\n    document.title = 'Home | Djackets'\n  },\n  methods: {\n    async getLatestProducts() {\n      // this.$store.commit('setIsLoading', true)\n      await axios\n        .get('/api/v1/latest-products/')\n        .then(response => {\n          this.latestProducts = response.data\n        })\n        .catch(error => {\n          console.log(error)\n        })\n      // this.$store.commit('setIsLoading', false)\n    }\n  }\n}\n</script>\n\n<style>\n.flexbox {\n  display: flex;\n  flex-wrap: wrap;\n  /* justify-content: space-between; */\n  align-items: center;\n  justify-content: center;\n}\n\n.flex-item {\n  margin-right: calc(1.5rem * 0.5);\n  margin-left: calc(1.5rem * 0.5);\n  margin-top: 1.5rem;\n}\n</style>\n"]},"metadata":{},"sourceType":"module","externalDependencies":[]}