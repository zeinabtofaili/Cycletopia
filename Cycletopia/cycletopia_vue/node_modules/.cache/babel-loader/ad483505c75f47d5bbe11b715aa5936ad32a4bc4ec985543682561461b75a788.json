{"ast":null,"code":"import axios from 'axios';\nimport ProductBox from '@/components/ProductCard';\nexport default {\n  name: 'HomeView',\n  data() {\n    return {\n      latestProducts: []\n    };\n  },\n  components: {\n    ProductCard\n  },\n  mounted() {\n    this.getLatestProducts();\n    document.title = 'Home | Djackets';\n  },\n  methods: {\n    async getLatestProducts() {\n      // this.$store.commit('setIsLoading', true)\n      await axios.get('/api/v1/latest-products/').then(response => {\n        this.latestProducts = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      // this.$store.commit('setIsLoading', false)\n    }\n  }\n};","map":{"version":3,"mappings":"AA2BA,OAAOA,KAAI,MAAO,OAAM;AACxB,OAAOC,UAAS,MAAO,0BAAyB;AAChD,eAAe;EACbC,IAAI,EAAE,UAAU;EAChBC,IAAI,GAAG;IACL,OAAO;MACLC,cAAc,EAAE;IAClB;EACF,CAAC;EACDC,UAAU,EAAE;IACVC;EACF,CAAC;EACDC,OAAO,GAAG;IACR,IAAI,CAACC,iBAAiB,EAAC;IACvBC,QAAQ,CAACC,KAAI,GAAI,iBAAgB;EACnC,CAAC;EACDC,OAAO,EAAE;IACP,MAAMH,iBAAiB,GAAG;MACxB;MACA,MAAMR,KAAI,CACPY,GAAG,CAAC,0BAA0B,EAC9BC,IAAI,CAACC,QAAO,IAAK;QAChB,IAAI,CAACV,cAAa,GAAIU,QAAQ,CAACX,IAAG;MACpC,CAAC,EACAY,KAAK,CAACC,KAAI,IAAK;QACdC,OAAO,CAACC,GAAG,CAACF,KAAK;MACnB,CAAC;MACH;IACF;EACF;AACF","names":["axios","ProductBox","name","data","latestProducts","components","ProductCard","mounted","getLatestProducts","document","title","methods","get","then","response","catch","error","console","log"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\views\\HomeView.vue"],"sourcesContent":["<template>\n  <div class=\"home\">\n    <section class=\"hero is-medium is-dark mb-6\">\n        <div class=\"hero-body has-text-centered\">\n            <p class=\"title mb-6\">\n                Welcome to Cycletopia\n            </p>\n            <p class=\"subtitle\">\n                The best jacket store online\n            </p>\n        </div>\n    </section>\n\n    <div class=\"columns is-multiline\">\n      <div class=\"column is-12\">\n          <h2 class=\"is-size-2 has-text-centered\">Latest products</h2>\n      </div>\n\n      <ProductCard \n        v-for=\"product in latestProducts\"\n        v-bind:key=\"product.id\"\n        v-bind:product=\"product\" />\n    </div>\n  </div>\n</template>\n\n<script>\nimport axios from 'axios'\nimport ProductBox from '@/components/ProductCard'\nexport default {\n  name: 'HomeView',\n  data() {\n    return {\n      latestProducts: []\n    }\n  },\n  components: {\n    ProductCard\n  },\n  mounted() {\n    this.getLatestProducts()\n    document.title = 'Home | Djackets'\n  },\n  methods: {\n    async getLatestProducts() {\n      // this.$store.commit('setIsLoading', true)\n      await axios\n        .get('/api/v1/latest-products/')\n        .then(response => {\n          this.latestProducts = response.data\n        })\n        .catch(error => {\n          console.log(error)\n        })\n      // this.$store.commit('setIsLoading', false)\n    }\n  }\n}\n</script>\n"]},"metadata":{},"sourceType":"module","externalDependencies":[]}