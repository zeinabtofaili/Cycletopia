{"ast":null,"code":"export default {\n  name: 'CartItem',\n  props: {\n    initialItem: Object\n  },\n  data() {\n    return {\n      item: this.initialItem\n    };\n  },\n  methods: {\n    getItemTotal(item) {\n      return item.quantity * item.product.price;\n    },\n    decrementQuantity(item) {\n      item.quantity -= 1;\n      if (item.quantity === 0) {\n        this.$emit('removeFromCart', item);\n      }\n      this.updateCart();\n    },\n    incrementQuantity(item) {\n      item.quantity += 1;\n      this.updateCart();\n    },\n    updateCart() {\n      localStorage.setItem('cart', JSON.stringify(this.$store.state.cart));\n    },\n    removeFromCart(item) {\n      this.$emit('removeFromCart', item);\n      this.updateCart();\n    }\n  }\n};","map":{"version":3,"mappings":"AAiCA,eAAe;EACXA,IAAI,EAAE,UAAU;EAChBC,KAAK,EAAE;IACHC,WAAW,EAAEC;EACjB,CAAC;EACDC,IAAI,GAAG;IACH,OAAO;MACHC,IAAI,EAAE,IAAI,CAACH;IACf;EACJ,CAAC;EACDI,OAAO,EAAE;IACLC,YAAY,CAACF,IAAI,EAAE;MACf,OAAOA,IAAI,CAACG,QAAO,GAAIH,IAAI,CAACI,OAAO,CAACC,KAAI;IAC5C,CAAC;IACDC,iBAAiB,CAACN,IAAI,EAAE;MACpBA,IAAI,CAACG,QAAO,IAAK;MACjB,IAAIH,IAAI,CAACG,QAAO,KAAM,CAAC,EAAE;QACrB,IAAI,CAACI,KAAK,CAAC,gBAAgB,EAAEP,IAAI;MACrC;MACA,IAAI,CAACQ,UAAU,EAAC;IACpB,CAAC;IACDC,iBAAiB,CAACT,IAAI,EAAE;MACpBA,IAAI,CAACG,QAAO,IAAK;MACjB,IAAI,CAACK,UAAU,EAAC;IACpB,CAAC;IACDA,UAAU,GAAG;MACTE,YAAY,CAACC,OAAO,CAAC,MAAM,EAAEC,IAAI,CAACC,SAAS,CAAC,IAAI,CAACC,MAAM,CAACC,KAAK,CAACC,IAAI,CAAC;IACvE,CAAC;IACDC,cAAc,CAACjB,IAAI,EAAE;MACjB,IAAI,CAACO,KAAK,CAAC,gBAAgB,EAAEP,IAAI;MACjC,IAAI,CAACQ,UAAU,EAAC;IACpB;EACJ;AACJ","names":["name","props","initialItem","Object","data","item","methods","getItemTotal","quantity","product","price","decrementQuantity","$emit","updateCart","incrementQuantity","localStorage","setItem","JSON","stringify","$store","state","cart","removeFromCart"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\components\\CartItem.vue"],"sourcesContent":["<template>\r\n    <div class=\"card 