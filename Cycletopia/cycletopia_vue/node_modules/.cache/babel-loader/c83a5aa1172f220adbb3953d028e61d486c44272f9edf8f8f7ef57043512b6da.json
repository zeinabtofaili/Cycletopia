{"ast":null,"code":"import axios from 'axios';\nimport CartItem from '@/components/CartItem.vue';\nexport default {\n  name: 'CartView',\n  components: {\n    CartItem\n  },\n  data() {\n    return {\n      cart: {\n        items: []\n      }\n    };\n  },\n  mounted() {\n    this.cart = this.$store.state.cart;\n  },\n  methods: {\n    removeFromCart(item) {\n      this.cart.items = this.cart.items.filter(i => i.product.id !== item.product.id);\n    }\n  },\n  computed: {\n    cartTotalLength() {\n      return this.cart.items.reduce((acc, curVal) => {\n        return acc += curVal.quantity;\n      }, 0);\n    },\n    cartTotalPrice() {\n      return this.cart.items.reduce((acc, curVal) => {\n        return acc += curVal.product.price * curVal.quantity;\n      }, 0);\n    }\n  }\n};","map":{"version":3,"mappings":"AAmCA,OAAOA,KAAI,MAAO,OAAM;AACxB,OAAOC,QAAO,MAAO,2BAA0B;AAC/C,eAAe;EACXC,IAAI,EAAE,UAAU;EAChBC,UAAU,EAAE;IACRF;EACJ,CAAC;EACDG,IAAI,GAAG;IACH,OAAO;MACHC,IAAI,EAAE;QACFC,KAAK,EAAE;MACX;IACJ;EACJ,CAAC;EACDC,OAAO,GAAG;IACN,IAAI,CAACF,IAAG,GAAI,IAAI,CAACG,MAAM,CAACC,KAAK,CAACJ,IAAG;EACrC,CAAC;EACDK,OAAO,EAAE;IACLC,cAAc,CAACC,IAAI,EAAE;MACjB,IAAI,CAACP,IAAI,CAACC,KAAI,GAAI,IAAI,CAACD,IAAI,CAACC,KAAK,CAACO,MAAM,CAACC,KAAKA,CAAC,CAACC,OAAO,CAACC,EAAC,KAAMJ,IAAI,CAACG,OAAO,CAACC,EAAE;IAClF;EACJ,CAAC;EACDC,QAAQ,EAAE;IACNC,eAAe,GAAG;MACd,OAAO,IAAI,CAACb,IAAI,CAACC,KAAK,CAACa,MAAM,CAAC,CAACC,GAAG,EAAEC,MAAM,KAAK;QAC3C,OAAOD,GAAE,IAAKC,MAAM,CAACC,QAAO;MAChC,CAAC,EAAE,CAAC;IACR,CAAC;IACDC,cAAc,GAAG;MACb,OAAO,IAAI,CAAClB,IAAI,CAACC,KAAK,CAACa,MAAM,CAAC,CAACC,GAAG,EAAEC,MAAM,KAAK;QAC3C,OAAOD,GAAE,IAAKC,MAAM,CAACN,OAAO,CAACS,KAAI,GAAIH,MAAM,CAACC,QAAO;MACvD,CAAC,EAAE,CAAC;IACR;EACJ;AACJ","names":["axios","CartItem","name","components","data","cart","items","mounted","$store","state","methods","removeFromCart","item","filter","i","product","id","computed","cartTotalLength","reduce","acc","curVal","quantity","cartTotalPrice","price"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\views\\CartView.vue"],"sourcesContent":["<template>\r\n\r\n    <div class=\"d-flex justify-content-between align-items-center mb-4\">\r\n        <h2 class=\"fw-normal mb-0 text-black\">Shopping Cart</h2>\r\n    </div>\r\n\r\n    <table class=\"table\" v-if=\"cartTotalLength\">\r\n        <thead>\r\n            <tr>\r\n                <th scope=\"col\">Product</th>\r\n                <th scope=\"col\">Price</th>\r\n                <th scope=\"col\">Quantity</th>\r\n                <th scope=\"col\">Total</th>\r\n                <th scope=\"col\"></th>\r\n            </tr>\r\n        </thead>\r\n        <tbody>\r\n            <CartItem v-for=\"item in cart.items\" v-bind:key=\"item.product.id\" v-bind:initialItem=\"item\"\r\n                v-on:removeFromCart=\"removeFromCart\" />\r\n        </tbody>\r\n    </table>\r\n    <p v-else>You don't have any products in your cart...</p>\r\n\r\n    <div class=\"mb-4\">\r\n        <h3 class=\"fw-normal mb-0 text-black\">Summary</h3>\r\n\r\n        <strong>${{ cartTotalPrice.toFixed(2) }}</strong>, {{ cartTotalLength }} items\r\n\r\n        <hr>\r\n\r\n        <router-link to=\"/cart/checkout\" class=\"btn btn-dark\">Proceed to checkout</router-link>\r\n    </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from 'axios'\r\nimport CartItem from '@/components/CartItem.vue'\r\nexport default {\r\n    name: 'CartView',\r\n    components: {\r\n        CartItem\r\n    },\r\n    data() {\r\n        return {\r\n            cart: {\r\n                items: []\r\n            }\r\n        }\r\n    },\r\n    mounted() {\r\n        this.cart = this.$store.state.cart\r\n    },\r\n    methods: {\r\n        removeFromCart(item) {\r\n            this.cart.items = this.cart.items.filter(i => i.product.id !== item.product.id)\r\n        }\r\n    },\r\n    computed: {\r\n        cartTotalLength() {\r\n            return this.cart.items.reduce((acc, curVal) => {\r\n                return acc += curVal.quantity\r\n            }, 0)\r\n        },\r\n        cartTotalPrice() {\r\n            return this.cart.items.reduce((acc, curVal) => {\r\n                return acc += curVal.product.price * curVal.quantity\r\n            }, 0)\r\n        },\r\n    }\r\n}\r\n</script>"]},"metadata":{},"sourceType":"module","externalDependencies":[]}