{"ast":null,"code":"export default {\n  mounted() {\n    document.title = 'About | Cycletopia';\n  }\n};","map":{"version":3,"mappings":"AA8DA,eAAe;EAEbA,OAAO,GAAG;IACRC,QAAQ,CAACC,KAAI,GAAI,oBAAmB;EACtC;AACF","names":["mounted","document","title"],"sourceRoot":"","sources":["C:\\Users\\HES\\Cycletopia\\cycletopia_vue\\src\\views\\AboutView.vue"],"sourcesContent":["<template>\n  <div class=\"about\">\n    <p>This is an about page</p>\n  </div>\n\n\n\n  <div class=\"container-fluid px-0\">\n    <div class=\"row\">\n      <div class=\"col-md-12\" style=\"background-image: url(https://via.placeholder.com/1920x1080.png?text=Background+Image); background-size: cover; background-position: center;\">\n        <div class=\"container py-5\">\n          <h1 class=\"text-white text-center\">About Cycletopia</h1>\n          <p class=\"lead text-white text-center\">\"Promoting cycling for a healthier and more sustainable Lebanon.\"</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"container py-5\">\n      <div class=\"row\">\n        <div class=\"col-md-6\">\n          <h2 class=\"mb-4\">Our Mission</h2>\n          <p class=\"mb-4\">At Cycletopia, our mission is to promote cycling as a healthier and more sustainable alternative to driving in Lebanon. We believe that cycling can help reduce air pollution, improve public health, and support local communities.</p>\n          <p class=\"mb-4\">We offer a variety of services to support cycling in Lebanon, including bike rentals, sales, and repairs, as well as cycling clothing and components. We also organize and promote cycling events, and provide professional training and support for cyclists of all levels.</p>\n          <a href=\"#\" class=\"btn btn-primary\">Learn More</a>\n        </div>\n        <div class=\"col-md-6\">\n          <img src=\"https://via.placeholder.com/600x400.png?text=Image+1\" class=\"img-fluid\" alt=\"\">\n        </div>\n      </div>\n    </div>\n\n    <div class=\"container py-5\">\n      <div class=\"row\">\n        <div class=\"col-md-6\">\n          <img src=\"https://via.placeholder.com/600x400.png?text=Image+2\" class=\"img-fluid\" alt=\"\">\n        </div>\n        <div class=\"col-md-6\">\n          <h2 class=\"mb-4\">Our Services</h2>\n          <ul class=\"list-group list-group-flush mb-4\">\n            <li class=\"list-group-item\">Bike rentals</li>\n            <li class=\"list-group-item\">Bike sales</li>\n            <li class=\"list-group-item\">Cycling clothing and components</li>\n            <li class=\"list-group-item\">Cycling events</li>\n            <li class=\"list-group-item\">Professional training</li>\n            <li class=\"list-group-item\">Bike donations</li>\n          </ul>\n          <a href=\"#\" class=\"btn btn-primary\">View Services</a>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"container py-5\">\n      <div class=\"row\">\n        <div class=\"col-md-6\">\n          <h2 class=\"mb-4\">Our Impact</h2>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n\n  mounted() {\n    document.title = 'About | Cycletopia'\n  },\n}\n</script>\n"]},"metadata":{},"sourceType":"module","externalDependencies":[]}