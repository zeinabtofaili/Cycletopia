{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from 'axios';\nimport OrderSummary from '@/components/OrderSummary.vue';\nimport UserBikes from '@/components/MyBikes.vue';\nexport default {\n  name: 'MyAccountView',\n  components: {\n    OrderSummary,\n    UserBikes\n  },\n  data() {\n    return {\n      orders: [],\n      bikes: []\n    };\n  },\n  mounted() {\n    document.title = 'My account | Cycletopia';\n    this.getMyOrders();\n    this.getMyBikes();\n  },\n  methods: {\n    logout() {\n      axios.defaults.headers.common[\"Authorization\"] = \"\";\n      localStorage.removeItem(\"token\");\n      localStorage.removeItem(\"userid\");\n      localStorage.removeItem(\"username\");\n      this.$store.commit('removeToken');\n      this.$router.push('/');\n    },\n    async getMyOrders() {\n      this.$store.commit('setIsLoading', true);\n      await axios.get('/api/v1/orders/').then(response => {\n        this.orders = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    },\n    async getMyBikes() {\n      this.$store.commit('setIsLoading', true);\n      await axios.get('/api/v1/current-user-bikes/').then(response => {\n        this.bikes = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    }\n  }\n};","map":{"version":3,"mappings":";AAkCA,OAAOA,KAAI,MAAO,OAAM;AAExB,OAAOC,YAAW,MAAO,+BAA8B;AACvD,OAAOC,SAAQ,MAAO,0BAAyB;AAE/C,eAAe;EACXC,IAAI,EAAE,eAAe;EACrBC,UAAU,EAAE;IACRH,YAAY;IACZC;EACJ,CAAC;EACDG,IAAI,GAAG;IACH,OAAO;MACHC,MAAM,EAAE,EAAE;MACVC,KAAK,EAAE;IACX;EACJ,CAAC;EACDC,OAAO,GAAG;IACNC,QAAQ,CAACC,KAAI,GAAI,yBAAwB;IAEzC,IAAI,CAACC,WAAW,EAAE;IAClB,IAAI,CAACC,UAAU,EAAE;EACrB,CAAC;EACDC,OAAO,EAAE;IACLC,MAAM,GAAG;MACLd,KAAK,CAACe,QAAQ,CAACC,OAAO,CAACC,MAAM,CAAC,eAAe,IAAI,EAAC;MAElDC,YAAY,CAACC,UAAU,CAAC,OAAO;MAC/BD,YAAY,CAACC,UAAU,CAAC,QAAQ;MAChCD,YAAY,CAACC,UAAU,CAA