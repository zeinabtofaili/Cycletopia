{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport axios from 'axios';\nimport OrderSummary from '@/components/OrderSummary.vue';\nimport { toast } from 'vue3-toastify';\nimport 'vue3-toastify/dist/index.css';\nimport VueModal from '@kouts/vue-modal';\nimport '@kouts/vue-modal/dist/vue-modal.css';\nexport default {\n  name: 'MyAccountView',\n  components: {\n    OrderSummary,\n    'Modal': VueModal\n  },\n  setup() {\n    const notify = () => {\n      toast(\"Delete bike successful. Please refresh the page to view changes.\", {\n        autoClose: 2000,\n        position: 'bottom-right',\n        type: 'success'\n      }); // ToastOptions\n    };\n\n    return {\n      notify\n    };\n  },\n  data() {\n    return {\n      orders: [],\n      bikes: [],\n      bikeIdtoDel: 0,\n      showModal: false\n    };\n  },\n  mounted() {\n    document.title = 'My account | Cycletopia';\n    this.getMyOrders();\n    this.getMyBikes();\n  },\n  methods: {\n    logout() {\n      axios.defaults.headers.common[\"Authorization\"] = \"\";\n      localStorage.removeItem(\"token\");\n      localStorage.removeItem(\"userid\");\n      localStorage.removeItem(\"username\");\n      this.$store.commit('removeToken');\n      this.$router.push('/');\n    },\n    async getMyOrders() {\n      this.$store.commit('setIsLoading', true);\n      await axios.get('/api/v1/orders/').then(response => {\n        this.orders = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    },\n    async getMyBikes() {\n      this.$store.commit('setIsLoading', true);\n      await axios.get('/api/v1/current-user-bikes/').then(response => {\n        this.bikes = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    },\n    async deleteBike() {\n      this.$store.commit('setIsLoading', true);\n      await axios.delete('/api/v1/delete-bike/' + bikeIdtoDel).then(response => {\n        console.log(\"Delete successful.\");\n        this.notify();\n      }).catch(error => {\n        console.log(error);\n      });\n      this.$store.commit('setIsLoading', false);\n    },\n    changeBikeIdToDelete(id) {\n      this.bikeIdtoDel = id;\n      console.log(this.bikeIdtoDel);\n      this.showModal = true;\n    }\n  }\n};","map":{"version":3,"mappings":";AA4DA,OAAOA,KAAI,MAAO,OAAM;AACxB,OAAOC,YAAW,MAAO,+BAA8B;AACvD,SAASC,KAAI,QAAS,eAAe;AACrC,OAAO,8BAA8B;AAErC,OAAOC,QAAO,MAAO,kBAAiB;AACtC,OAAO,qCAAoC;AAC3C,eAAe;EACXC,IAAI,EAAE,eAAe;EACrBC,UAAU,EAAE;IACRJ,YAAY;IACZ,OAAO,EAAEE;EACb,CAAC;EACDG,KAAK,GAAG;IACJ,MAAMC,MAAK,GAAI,MAAM;MACjBL,KAAK,CAAC,kEAAkE,EAAE;QACtEM,SAAS,EAAE,IAAI;QACfC,QAAQ,EAAE,cAAc;QACxBC,IAAI,EAAE;MACV,CAAC,CAAC,EAAE;IACR;;IACA,OAAO;MAAEH;IAAO,CAAC;EACrB,CAAC;EACDI,IAAI,GAAG;IACH,OAAO;MACHC,MAAM,EAAE,EAAE;MACVC,KAAK,EAAE,EAAE;MACTC,WAAW,EAAE,CAAC;MACdC,SAAS,EAAE;IACf;EACJ,CAAC;EACDC,OAAO,GAAG;IACNC,QAAQ,CAACC,KAAI,GAAI,yBAAwB;IAEzC,IAAI,CAACC,WAAW,EAAE;IAClB,IAAI,CAACC,UAAU,EAAE;EACrB,CAAC;EACDC,OAAO,EAAE;IACLC,MAAM,GAAG;MACLtB,KAAK,CAACuB,QAAQ,CAACC,OAAO,CAACC,MAAM,CAAC,eAAe,IAAI,EAAC;MAElDC,YAAY,CAACC,UAAU,CAAC,OAAO;MAC/BD,YAAY,CAACC,UAAU,CAAC,QAAQ;MAChCD,YAAY,CAACC,UAAU,CAAC,UAAU;MAElC,IAAI,CAACC,MAAM,CAACC,MAAM,CAAC,aAAa;MAEhC,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,GAAG;IACzB,CAAC;IACD,MAAMZ,WAAW,GAAG;MAChB,IAAI,CAACS,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,IAAI;MAEvC,MAAM7B,KAAI,CACLgC,GAAG,CAAC,iBAAiB,EACrBC,IAAI,CAACC,QAAO,IAAK;QACd,IAAI,CAACtB,MAAK,GAAIsB,QAAQ,CAACvB,IAAG;MAC9B,CAAC,EACAwB,KAAK,CAACC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAG,CAACF,KAAK;MACrB,CAAC;MAEL,IAAI,CAACR,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,KAAK;IAC5C,CAAC;IACD,MAAMT,UAAU,GAAG;MACf,IAAI,CAACQ,MAAM,CAACC,MAAM,CAAC,cAAc,EAAE,IAAI;MAEvC,MAAM7B,KAAI,CACLgC,GAAG,CAAC,6BAA6B,EACjCC,IAAI,CAACC,QAAO,IAAK;QACd,IAAI,CAACrB,KAAI,GAAIqB,QAAQ,CAACvB,IAAG;MAC7B,CAAC,EACAwB,KAAK,CAACC,KAAI,IAAK;QACZC,OAAO,CAACC,GAAG,CAACF,KAAK;MACrB,CAAC;MAEL,IAAI,CAACR,MAAM,