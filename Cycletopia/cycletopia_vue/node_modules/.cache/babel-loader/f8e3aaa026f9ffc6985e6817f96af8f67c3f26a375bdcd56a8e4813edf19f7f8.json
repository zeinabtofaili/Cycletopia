scription,\n          grouping: this.grouping,\n          size: this.size,\n          color: this.color,\n          price: this.price,\n          sellerPhoneNumber: this.sellerPhoneNumber,\n          sold: false,\n          address: this.address,\n          slug: this.slug\n        };\n        const headers = {\n          headers: {\n            'Content-Type': 'multipart/form-data'\n          }\n        };\n        axios.post(\"/api/v1/sell-bike/\", formData, headers).then(response => {\n          console.log(response);\n        }).catch(error => {\n          console.log(error);\n        });\n      }\n    }\n  }\n};","map":{"version":3,"mappings":";AAuEA,OAAOA,KAAI,MAAO,OAAM;AAExB,eAAe;EACXC,IAAI,EAAE,cAAc;EACpBC,OAAO,GAAG;IACNC,QAAQ,CAACC,KAAI,GAAI,6BAA4B;EACjD,CAAC;EACDC,IAAI,GAAG;IACH,OAAO;MACHC,WAAW,EAAE,EAAE;MACfL,IAAI,EAAE,EAAE;MACRM,WAAW,EAAE,EAAE;MACfC,QAAQ,EAAE,EAAE;MACZC,IAAI,EAAE,EAAE;MACRC,KAAK,EAAE,EAAE;MACTC,KAAK,EAAE,EAAE;MACTC,iBAAiB,EAAE,EAAE;MACrBC,OAAO,EAAE,EAAE;MACXC,YAAY,EAAEC,SAAS;MACvBC,IAAI,EAAE,EAAE;MACRC,MAAM,EAAE;IACZ;EACJ,CAAC;EACDC,OAAO,EAAE;IACLC,YAAY,CAACC,CAAC,EAAE;MACZ,IAAIC,UAAS,GAAIlB,QAAQ,CAACmB,cAAc,CAAC,YAAY;MACrD,IAAI,CAACR,YAAW,GAAIO,UAAU,CAACE,KAAK,CAAC,CAAC;IAC1C,CAAC;IACDC,UAAU,GAAG;MACT,IAAI,CAACP,MAAK,GAAI,EAAC;MACf,IAAI,IAAI,CAAChB,IAAG,KAAM,EAAE,EAAE;QAClB,IAAI,CAACgB,MAAM,CAACQ,IAAI,CAAC,4BAA4B;MACjD;MACA,IAAI,IAAI,CAAClB,WAAU,KAAM,EAAE,EAAE;QACzB,IAAI,CAACU,MAAM,CAACQ,IAAI,CAAC,mCAAmC;MACxD;MACA,IAAI,IAAI,CAACnB,WAAU,KAAM,EAAE,EAAE;QACzB,IAAI,CAACW,MAAM,CAACQ,IAAI,CAAC,6BAA6B;MAClD;MACA,IAAI,IAAI,CAACb,iBAAgB,KAAM,EAAE,EAAE;QAC/B,IAAI,CAACK,MAAM,CAACQ,IAAI,CAAC,6BAA6B;MAClD;MACA,IAAI,IAAI,CAACZ,OAAM,KAAM,EAAE,EAAE;QACrB,IAAI,CAACI,MAAM,CAACQ,IAAI,CAAC,+BAA+B;MACpD;MACA,IAAI,IAAI,CAACjB,QAAO,KAAM,EAAE,EAAE;QACtB,IAAI,CAACS,MAAM,CAACQ,IAAI,CAAC,4BAA4B;MACjD;MACA,IAAI,IAAI,CAAChB,IAAG,KAAM,EAAE,EAAE;QAClB,IAAI,CAACQ,MAAM,CAACQ,IAAI,CAAC,4BAA4B;MACjD;MACA,IAAI,IAAI,CAACd,KAAI,KAAM,EAAE,EAAE;QACnB,IAAI,CAACM,MAAM,CAACQ,IA